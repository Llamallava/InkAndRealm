@inherits LayoutComponentBase
@using InkAndRealm.Client.State
@inject UserState UserState

<div class="page">
    <main @onclick="CloseLoginPanel">
        <div class="top-row px-4">
            <SectionOutlet SectionName="top-bar-left" />
            <div class="top-row-actions">
                <button class="btn account-icon-btn" @onclick="ToggleLoginPanel" @onclick:stopPropagation title="@(UserState.CurrentUser is null ? "Account" : UserState.CurrentUser.Username)">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true">
                        <path d="M12 12c2.97 0 5.4-2.43 5.4-5.4S14.97 1.2 12 1.2 6.6 3.63 6.6 6.6 9.03 12 12 12zm0 2.7c-3.6 0-10.8 1.8-10.8 5.4v2.7h21.6v-2.7c0-3.6-7.2-5.4-10.8-5.4z"/>
                    </svg>
                    @if (UserState.CurrentUser is not null)
                    {
                        <span class="account-icon-label">@UserState.CurrentUser.Username</span>
                    }
                </button>
                @if (isLoginPanelOpen)
                {
                    <div class="login-panel" @onclick:stopPropagation>
                        <AccountPanel Compact="true" OnCompleted="CloseLoginPanelAsync" />
                    </div>
                }
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool isLoginPanelOpen;

    protected override async Task OnInitializedAsync()
    {
        await UserState.InitializeAsync();
    }

    private void ToggleLoginPanel()
    {
        isLoginPanelOpen = !isLoginPanelOpen;
    }

    private void CloseLoginPanel()
    {
        isLoginPanelOpen = false;
    }

    private Task CloseLoginPanelAsync()
    {
        isLoginPanelOpen = false;
        return Task.CompletedTask;
    }
}
