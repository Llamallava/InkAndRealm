    private async Task PerformExportAsync()
    {
        var fileName = string.IsNullOrWhiteSpace(_exportFileName) ? $"map-{MapId}" : _exportFileName.Trim();
        var renderState = BuildRenderState();
        renderState.ViewState = new MapViewStateDto
        {
            ViewX = 0,
            ViewY = 0,
            Zoom = 1,
            MapWidth = MapWidth,
            MapHeight = MapHeight
        };
        renderState.ActivePolygon = null;
        renderState.EditPolygon = null;
        renderState.EditPolygonPointIndex = null;
        renderState.EditPolygonEdgeIndex = null;
        renderState.EditPolygonCenterActive = false;
        renderState.BrushPreview = null;
        renderState.EditPointFeature = null;
        await JS.InvokeVoidAsync("inkAndRealmDemo.exportFullMap", renderState, fileName);
        _isExportMenuOpen = false;
    }

    private async Task LoadPostSettingsDataAsync()
    {
        if (MapId <= 0 || !IsLoggedIn) return;
        _postSettingsLoading = true;
        StateHasChanged();

        var sessionToken = UserState.CurrentUser?.SessionToken;
        var userId = UserState.CurrentUser?.UserId;

        // Load map summary for IsPublished
        string summaryUrl = !string.IsNullOrWhiteSpace(sessionToken)
            ? $"api/map?sessionToken={Uri.EscapeDataString(sessionToken)}"
            : userId is null ? "api/map" : $"api/map?userId={userId.Value}";

        try
        {
            var maps = await Http.GetFromJsonAsync<List<MapSummaryDto>>(summaryUrl);
            _postSummary = maps?.FirstOrDefault(m => m.Id == MapId);
        }
        catch { /* non-critical */ }

        // Load share status
        string shareUrl = !string.IsNullOrWhiteSpace(sessionToken)
            ? $"api/map/share?sessionToken={Uri.EscapeDataString(sessionToken)}"
            : userId is null ? "api/map/share" : $"api/map/share?userId={userId.Value}";

        try
        {
            var shares = await Http.GetFromJsonAsync<List<MapShareStatusDto>>(shareUrl);
            _postShare = shares?.FirstOrDefault(s => s.MapId == MapId);
        }
        catch { /* non-critical */ }

        // Load engagement (views + likes)
        string engagementUrl = !string.IsNullOrWhiteSpace(sessionToken)
            ? $"api/map/engagement/{MapId}?sessionToken={Uri.EscapeDataString(sessionToken)}"
            : userId is null ? $"api/map/engagement/{MapId}" : $"api/map/engagement/{MapId}?userId={userId.Value}";

        try
        {
            _postEngagement = await Http.GetFromJsonAsync<MapEngagementDto>(engagementUrl);
        }
        catch { /* non-critical */ }

        _postSettingsLoading = false;
    }

    private async Task PostPublishAsync()
    {
        if (MapId <= 0 || _postPublishBusy) return;
        _postPublishBusy = true;
        _postStatusMessage = null;

        var response = await Http.PostAsJsonAsync("api/map/publish", new PublishMapRequest
        {
            UserId = UserState.CurrentUser?.UserId,
            SessionToken = UserState.CurrentUser?.SessionToken,
            MapId = MapId
        });

        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            await UserState.SetUserAsync(null);
            Navigation.NavigateTo("/");
            return;
        }

        if (response.IsSuccessStatusCode)
        {
            _postSummary = await response.Content.ReadFromJsonAsync<MapSummaryDto>();
        }
        else
        {
            var msg = await response.Content.ReadAsStringAsync();
            _postStatusMessage = string.IsNullOrWhiteSpace(msg) ? "Failed to publish map." : msg;
        }

        _postPublishBusy = false;
    }

