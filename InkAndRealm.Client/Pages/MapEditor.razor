    private static string FormatAspectRatio(float w, float h)
    {
        if (w <= 0 || h <= 0) return "—";
        var gcd = Gcd((int)w, (int)h);
        return $"{(int)w / gcd}:{(int)h / gcd}";
    }

    private static int Gcd(int a, int b) => b == 0 ? a : Gcd(b, a % b);

