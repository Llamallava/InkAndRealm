    private LiveMapSnapshot CaptureLiveSnapshot() => new LiveMapSnapshot
    {
        Trees = CloneList(_liveTrees),
        Houses = CloneList(_liveHouses),
        Characters = CloneList(_liveCharacters),
        Titles = CloneList(_liveTitles),
        WaterPolygons = CloneList(_liveWaterPolygons),
        LandPolygons = CloneList(_liveLandPolygons),
        BackgroundColor = _backgroundColor,
        ShowGrid = _showGrid,
        MapStyle = _mapStyle,
        MapWidth = _mapWidth,
        MapHeight = _mapHeight
    };

    private MapEditsRequest ComputeDiff(LiveMapSnapshot saved)
    {
        // Trees
        var savedTreeMap = saved.Trees.Where(t => t.Id > 0).ToDictionary(t => t.Id);
        var liveTreeIds = _liveTrees.Where(t => t.Id > 0).Select(t => t.Id).ToHashSet();
        var addedTrees = _liveTrees.Where(t => t.Id == 0).ToList();
        var updatedTrees = _liveTrees
            .Where(t => t.Id > 0 && savedTreeMap.TryGetValue(t.Id, out var s) && !AreEqualByJson(t, s))
            .ToList();
        var deletedTreeIds = saved.Trees
            .Where(t => t.Id > 0 && !liveTreeIds.Contains(t.Id))
            .Select(t => t.Id).ToList();

        // Houses
        var savedHouseMap = saved.Houses.Where(h => h.Id > 0).ToDictionary(h => h.Id);
        var liveHouseIds = _liveHouses.Where(h => h.Id > 0).Select(h => h.Id).ToHashSet();
        var addedHouses = _liveHouses.Where(h => h.Id == 0).ToList();
        var updatedHouses = _liveHouses
            .Where(h => h.Id > 0 && savedHouseMap.TryGetValue(h.Id, out var s) && !AreEqualByJson(h, s))
            .ToList();
        var deletedHouseIds = saved.Houses
            .Where(h => h.Id > 0 && !liveHouseIds.Contains(h.Id))
            .Select(h => h.Id).ToList();

        // Titles
        var savedTitleMap = saved.Titles.Where(t => t.Id > 0).ToDictionary(t => t.Id);
        var liveTitleIds = _liveTitles.Where(t => t.Id > 0).Select(t => t.Id).ToHashSet();
        var addedTitles = _liveTitles.Where(t => t.Id == 0).ToList();
        var updatedTitles = _liveTitles
            .Where(t => t.Id > 0 && savedTitleMap.TryGetValue(t.Id, out var s) && !AreEqualByJson(t, s))
            .ToList();
        var deletedTitleIds = saved.Titles
            .Where(t => t.Id > 0 && !liveTitleIds.Contains(t.Id))
            .Select(t => t.Id).ToList();

        // Water polygons
        var savedWaterMap = saved.WaterPolygons.Where(p => p.Id > 0).ToDictionary(p => p.Id);
        var liveWaterIds = _liveWaterPolygons.Where(p => p.Id > 0).Select(p => p.Id).ToHashSet();
        var addedWater = _liveWaterPolygons.Where(p => p.Id == 0).ToList();
        var updatedWater = _liveWaterPolygons
            .Where(p => p.Id > 0 && savedWaterMap.TryGetValue(p.Id, out var s) && !AreEqualByJson(p, s))
            .ToList();
        var deletedWaterIds = saved.WaterPolygons
            .Where(p => p.Id > 0 && !liveWaterIds.Contains(p.Id))
            .Select(p => p.Id).ToList();

        // Land polygons
        var savedLandMap = saved.LandPolygons.Where(p => p.Id > 0).ToDictionary(p => p.Id);
        var liveLandIds = _liveLandPolygons.Where(p => p.Id > 0).Select(p => p.Id).ToHashSet();
        var addedLand = _liveLandPolygons.Where(p => p.Id == 0).ToList();
        var updatedLand = _liveLandPolygons
            .Where(p => p.Id > 0 && savedLandMap.TryGetValue(p.Id, out var s) && !AreEqualByJson(p, s))
            .ToList();
        var deletedLandIds = saved.LandPolygons
            .Where(p => p.Id > 0 && !liveLandIds.Contains(p.Id))
            .Select(p => p.Id).ToList();

        // Characters + relationships
        var savedCharMap = saved.Characters.Where(c => c.Id > 0).ToDictionary(c => c.Id);
        var liveCharIds = _liveCharacters.Where(c => c.Id > 0).Select(c => c.Id).ToHashSet();
        var addedCharacters = _liveCharacters.Where(c => c.Id == 0).ToList();
        var updatedCharacters = new List<CharacterFeatureDto>();
        var addedRelationships = new List<AddCharacterRelationshipDto>();
        var updatedRelationships = new List<UpdateCharacterRelationshipDto>();
        var deletedRelationshipIds = new List<int>();

        foreach (var liveChar in _liveCharacters.Where(c => c.Id > 0))
        {
            if (!savedCharMap.TryGetValue(liveChar.Id, out var savedChar))
                continue;

            // Compare character fields only (relationships handled separately below)
            var liveJson = JsonSerializer.Serialize(new
            {
                liveChar.Id, liveChar.X, liveChar.Y, liveChar.CharacterType,
                liveChar.Name, liveChar.Background, liveChar.Occupation,
                liveChar.Personality, liveChar.LayerIndex
            });
            var savedJson = JsonSerializer.Serialize(new
            {
                savedChar.Id, savedChar.X, savedChar.Y, savedChar.CharacterType,
                savedChar.Name, savedChar.Background, savedChar.Occupation,
                savedChar.Personality, savedChar.LayerIndex
            });
            if (liveJson != savedJson)
                updatedCharacters.Add(liveChar);

            // Relationship diff
            var savedRelMap = savedChar.Relationships.Where(r => r.Id > 0).ToDictionary(r => r.Id);
            var liveRelIds = liveChar.Relationships.Where(r => r.Id > 0).Select(r => r.Id).ToHashSet();

            foreach (var liveRel in liveChar.Relationships.Where(r => r.Id == 0))
            {
                addedRelationships.Add(new AddCharacterRelationshipDto
                {
                    SourceCharacterId = liveChar.Id,
                    TargetFeatureId = liveRel.TargetFeatureId,
                    RelationshipTypes = new List<string>(liveRel.RelationshipTypes),
                    Description = liveRel.Description
                });
            }

            foreach (var liveRel in liveChar.Relationships.Where(r => r.Id > 0))
            {
                if (savedRelMap.TryGetValue(liveRel.Id, out var savedRel) && !AreEqualByJson(liveRel, savedRel))
                {
                    updatedRelationships.Add(new UpdateCharacterRelationshipDto
                    {
                        Id = liveRel.Id,
                        SourceCharacterId = liveChar.Id,
                        TargetFeatureId = liveRel.TargetFeatureId,
                        RelationshipTypes = new List<string>(liveRel.RelationshipTypes),
                        Description = liveRel.Description
                    });
                }
            }

            foreach (var savedRel in savedChar.Relationships.Where(r => r.Id > 0))
            {
                if (!liveRelIds.Contains(savedRel.Id))
                    deletedRelationshipIds.Add(savedRel.Id);
            }
        }

        var deletedCharacterIds = saved.Characters
            .Where(c => c.Id > 0 && !liveCharIds.Contains(c.Id))
            .Select(c => c.Id).ToList();

        return new MapEditsRequest
        {
            UserId = UserState.CurrentUser?.UserId,
            SessionToken = UserState.CurrentUser?.SessionToken,
            MapId = MapId,
            BackgroundColor = _backgroundColor != saved.BackgroundColor ? _backgroundColor : null,
            ShowGrid = _showGrid != saved.ShowGrid ? _showGrid : null,
            MapStyle = _mapStyle != saved.MapStyle ? _mapStyle : null,
            Width = _mapWidth != saved.MapWidth ? _mapWidth : null,
            Height = _mapHeight != saved.MapHeight ? _mapHeight : null,
            AreaLayers = _areaLayers.OrderBy(l => l.LayerIndex).Select(l => new AreaLayerDto
            {
                LayerKey = l.LayerKey,
                LayerIndex = l.LayerIndex,
                FeatureType = l.FeatureType
            }).ToList(),
            AddedTrees = addedTrees,
            UpdatedTrees = updatedTrees,
            DeletedTreeIds = deletedTreeIds,
            AddedHouses = addedHouses,
            UpdatedHouses = updatedHouses,
            DeletedHouseIds = deletedHouseIds,
            AddedCharacters = addedCharacters,
            UpdatedCharacters = updatedCharacters,
            DeletedCharacterIds = deletedCharacterIds,
            AddedTitles = addedTitles,
            UpdatedTitles = updatedTitles,
            DeletedTitleIds = deletedTitleIds,
            AddedRelationships = addedRelationships,
            UpdatedRelationships = updatedRelationships,
            DeletedRelationshipIds = deletedRelationshipIds,
            AddedWaterPolygons = addedWater,
            UpdatedWaterPolygons = updatedWater,
            DeletedWaterPolygonIds = deletedWaterIds,
            AddedLandPolygons = addedLand,
            UpdatedLandPolygons = updatedLand,
            DeletedLandPolygonIds = deletedLandIds
        };
    }

    private static bool DiffHasChanges(MapEditsRequest diff) =>
        diff.AddedTrees.Count > 0 || diff.UpdatedTrees.Count > 0 || diff.DeletedTreeIds.Count > 0
        || diff.AddedHouses.Count > 0 || diff.UpdatedHouses.Count > 0 || diff.DeletedHouseIds.Count > 0
        || diff.AddedCharacters.Count > 0 || diff.UpdatedCharacters.Count > 0 || diff.DeletedCharacterIds.Count > 0
        || diff.AddedTitles.Count > 0 || diff.UpdatedTitles.Count > 0 || diff.DeletedTitleIds.Count > 0
        || diff.AddedRelationships.Count > 0 || diff.UpdatedRelationships.Count > 0 || diff.DeletedRelationshipIds.Count > 0
        || diff.AddedWaterPolygons.Count > 0 || diff.UpdatedWaterPolygons.Count > 0 || diff.DeletedWaterPolygonIds.Count > 0
        || diff.AddedLandPolygons.Count > 0 || diff.UpdatedLandPolygons.Count > 0 || diff.DeletedLandPolygonIds.Count > 0
        || diff.BackgroundColor is not null || diff.ShowGrid.HasValue || diff.MapStyle is not null
        || diff.Width.HasValue || diff.Height.HasValue;

    // Full serialization catches nested changes (e.g. relationship list mutations) without
    // per-field comparison code. Acceptable cost since saves are infrequent.
    private static bool AreEqualByJson<T>(T a, T b) =>
        JsonSerializer.Serialize(a) == JsonSerializer.Serialize(b);

    private bool IsBlockingActionActive =>
        _isBrushing || _isErasing || _isDraggingEditPolygon || _isDraggingEditPoint ||
        _isDraggingEditPointFeature || _isDraggingTitleFeature || _isCharacterEditorOpen ||
        _isRelationshipTreeOpen || _isSaving || _isPointFeatureEditorOpen || _isRepositioning;

    // Called after any operation that may have unblocked auto-save. Flushes any pending save.
    private void TryReturnToIdle()
    {
        if (IsBlockingActionActive) return;
        if (_autoSavePending)
        {
            _autoSavePending = false;
            _ = AutoSaveFiredAsync();
        }
    }

    private async Task AutoSaveFiredAsync()
    {
        if (!HasUnsavedChanges || !IsLoggedIn || !_hasMap)
            return;
        await SaveEditsAsync();
        StateHasChanged();
    }

    // The first PushUndoState inside a batch records a snapshot; subsequent pushes
    // are no-ops. EndUndoBatch(false) pops the snapshot if the op produced no changes.
    private void BeginUndoBatch(UndoBatchKind kind)
    {
        _undoBatchKind = kind;
        _undoBatchPushed = false;
    }

    private void EndUndoBatch(bool keepChanges)
    {
        if (_undoBatchKind == UndoBatchKind.None)
        {
            return;
        }

        if (!keepChanges && _undoBatchPushed && _undoStack.Count > 0)
        {
            _undoStack.RemoveAt(_undoStack.Count - 1);
        }

        _undoBatchKind = UndoBatchKind.None;
        _undoBatchPushed = false;
    }

    private void PushUndoState()
    {
        if (_isUndoing)
        {
            return;
        }

        if (_undoBatchKind != UndoBatchKind.None && _undoBatchPushed)
        {
            return;
        }

        // Any new user action invalidates the redo history.
        if (!_isRedoing && _redoStack.Count > 0)
        {
            _redoStack.Clear();
        }

        _undoStack.Add(CaptureUndoState());

        if (_undoBatchKind != UndoBatchKind.None)
        {
            _undoBatchPushed = true;
        }
    }

    private UndoState CaptureUndoState()
    {
        return new UndoState
        {
            Trees = CloneList(_liveTrees),
            Houses = CloneList(_liveHouses),
            Titles = CloneList(_liveTitles),
            WaterPolygons = CloneList(_liveWaterPolygons),
            LandPolygons = CloneList(_liveLandPolygons),
            AreaLayers = CloneList(_areaLayers),
            ActiveAreaLayerKey = _activeAreaLayer?.LayerKey,
            ActiveAreaLayerIndex = _activeAreaLayer?.LayerIndex,
            LastX = _lastX,
            LastY = _lastY,
            HasLastPlacement = _hasLastPlacement
        };
    }

    private void ApplyUndoState(UndoState state)
    {
        ReplaceListContents(_liveTrees, state.Trees);
        ReplaceListContents(_liveHouses, state.Houses);
        ReplaceListContents(_liveTitles, state.Titles);
        ReplaceListContents(_liveWaterPolygons, state.WaterPolygons);
        ReplaceListContents(_liveLandPolygons, state.LandPolygons);
        ReplaceListContents(_areaLayers, state.AreaLayers);

        _activeAreaLayer = null;
        if (!string.IsNullOrWhiteSpace(state.ActiveAreaLayerKey))
        {
            _activeAreaLayer = _areaLayers.FirstOrDefault(layer => layer.LayerKey == state.ActiveAreaLayerKey);
        }

        if (_activeAreaLayer is null && state.ActiveAreaLayerIndex is not null)
        {
            _activeAreaLayer = _areaLayers.FirstOrDefault(layer => layer.LayerIndex == state.ActiveAreaLayerIndex.Value);
        }

        if (_activeAreaLayer is null && _areaLayers.Count > 0)
        {
            _activeAreaLayer = _areaLayers.OrderBy(layer => layer.LayerIndex).First();
        }

        _lastX = state.LastX;
        _lastY = state.LastY;
        _hasLastPlacement = state.HasLastPlacement;

        _activePolygonPoints.Clear();
        _isBrushing = false;
        _brushStrokeCount = 0;
        _isErasing = false;
        _eraseCount = 0;
        _hasBrushCursor = false;
    }

    private static List<T> CloneList<T>(IEnumerable<T> source)
    {
        return CloneDto(source.ToList());
    }

    private static Dictionary<int, T> CloneDictionary<T>(Dictionary<int, T> source)
    {
        return source.ToDictionary(entry => entry.Key, entry => CloneDto(entry.Value));
    }

    private static void ReplaceListContents<T>(List<T> target, List<T> source)
    {
        target.Clear();
        target.AddRange(source);
    }

    private static void ReplaceDictionaryContents<T>(Dictionary<int, T> target, Dictionary<int, T> source)
    {
        target.Clear();
        foreach (var entry in source)
        {
            target[entry.Key] = entry.Value;
        }
    }

    private static void ReplaceSetContents<T>(HashSet<T> target, HashSet<T> source)
    {
        target.Clear();
        foreach (var value in source)
        {
            target.Add(value);
        }
    }

    private async Task UpdateCanvasClientSizeAsync()
    {
        var size = await JS.InvokeAsync<CanvasClientSize?>("inkAndRealmDemo.getCanvasClientSize", CanvasId);
        if (size is null || size.Width <= 0 || size.Height <= 0)
        {
            _canvasClientWidth = CanvasWidth;
            _canvasClientHeight = CanvasHeight;
            return;
        }

        _canvasClientWidth = size.Width;
        _canvasClientHeight = size.Height;
    }

    private string GetStyleForPlacement(PlacementType placementType)
    {
        if (_selectedStyleByPlacement.TryGetValue(placementType, out var style)
            && !string.IsNullOrWhiteSpace(style))
        {
            return style;
        }

        var fallbackStyle = FeatureStyleDefinitions
            .FirstOrDefault(definition => definition.PlacementType == placementType)?
            .Styles
            .FirstOrDefault();

        return fallbackStyle ?? string.Empty;
    }

    private string GetStyleImageUrl(PlacementType placementType, string style)
    {
        if (StylePreviewImagesByPlacement.TryGetValue(placementType, out var stylePreviewMap)
            && stylePreviewMap.TryGetValue(style, out var imageUrl)
            && !string.IsNullOrWhiteSpace(imageUrl))
        {
            return imageUrl;
        }

        var placementImage = PlacementDefinitions
            .FirstOrDefault(definition => definition.PlacementType == placementType)?
            .ImageUrl;

        return placementImage ?? "/assets/character-placeholder.svg";
    }

    private float GetPointSizeForPlacement(PlacementType placementType)
    {
        if (!IsPointPlacement(placementType))
        {
            return 1f;
        }

        return _pointSizeByPlacement.TryGetValue(placementType, out var size)
            ? size
            : 1f;
    }

    private void SetPointSizeForPlacement(PlacementType placementType, float value)
    {
        if (!IsPointPlacement(placementType))
        {
            return;
        }

        _pointSizeByPlacement[placementType] = NormalizePointSize(value);
    }

    private static bool IsPointPlacement(PlacementType placementType)
    {
        return placementType == PlacementType.Tree
            || placementType == PlacementType.House
            || placementType == PlacementType.Character;
    }

    private static bool IsTitlePlacement(PlacementType placementType)
    {
        return placementType == PlacementType.Title;
    }

    private static bool CanDragTitle(TitleFeatureDto title)
    {
        return !title.TargetFeatureId.HasValue
            && (title.Points is null || title.Points.Count < 3);
    }

    private bool IsEditingTitlePolygon()
    {
        return _editingTitleFeature is not null
            && _editingPolygon is not null
            && string.Equals(_editingPolygon.FeatureType, "Title", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsLandFeatureType(string? featureType)
    {
        return string.Equals(featureType, "Land", StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsWaterFeatureType(string? featureType)
    {
        return string.Equals(featureType, "Water", StringComparison.OrdinalIgnoreCase);
    }

    private string GetAreaPlacementFeatureType()
    {
        return _placementType == PlacementType.Land ? "Land" : "Water";
    }

    private static float NormalizePointSize(float size)
    {
        return float.IsFinite(size) && size > 0f ? size : 1f;
    }

    private static string NormalizeTitleName(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "Untitled";
        }

        var trimmed = name.Trim();
        return trimmed.Length <= TitleNameMaxLength ? trimmed : trimmed[..TitleNameMaxLength];
    }

    private static float NormalizeTitleSize(float size)
    {
        if (!float.IsFinite(size))
        {
            return 1f;
        }

        if (size < TitleSizeMin)
        {
            return TitleSizeMin;
        }

        if (size > TitleSizeMax)
        {
            return TitleSizeMax;
        }

        return size;
    }

    private float GetCanvasScaleX()
    {
        return _canvasClientWidth > 0 ? (CanvasWidth / _canvasClientWidth) : 1f;
    }

    private float GetCanvasScaleY()
    {
        return _canvasClientHeight > 0 ? (CanvasHeight / _canvasClientHeight) : 1f;
    }

    // keepChanges=false physically reverts polygon vertices / feature position to their
    // pre-edit originals. keepChanges=true leaves mutations in place (right-click confirm).
    private void ClearEditSelection(bool keepChanges)
    {
        if (!keepChanges && _editingPolygon is not null && _editingOriginalPoints is not null)
        {
            var restoredPoints = _editingOriginalPoints
                .Select(point => new MapPointDto { X = point.X, Y = point.Y })
                .ToList();
            if (IsEditingTitlePolygon() && _editingTitleFeature is not null)
            {
                _editingTitleFeature.Title.Points = restoredPoints;
                _editingPolygon.Points = _editingTitleFeature.Title.Points;
            }
            else
            {
                _editingPolygon.Points = restoredPoints;
            }
        }

        if (!keepChanges && _editingPointFeature is not null && _editingPointOriginalPosition is not null)
        {
            if (_editingPointFeature.Character is null)
            {
                UpdatePointFeaturePosition(_editingPointFeature, _editingPointOriginalPosition.X, _editingPointOriginalPosition.Y);
            }
        }

        if (!keepChanges && _editingTitleFeature is not null && _editingTitleOriginalPosition is not null)
        {
            _editingTitleFeature.Title.X = _editingTitleOriginalPosition.X;
            _editingTitleFeature.Title.Y = _editingTitleOriginalPosition.Y;
        }

        if (!_isUndoing && _undoBatchKind == UndoBatchKind.Edit)
        {
            EndUndoBatch(keepChanges && _undoBatchPushed);
        }

        _editingPolygon = null;
        _editingOriginalPoints = null;
        _editingPointIndex = -1;
        _editingEdgeIndex = -1;
        _isDraggingEditPoint = false;
        _isDraggingEditPolygon = false;
        _editingPolygonDragOrigin = null;
        _editingPolygonDragOriginPoints = null;
        _editingPointFeature = null;
        _editingPointOriginalPosition = null;
        _isDraggingEditPointFeature = false;
        _isPointFeatureEditorOpen = false;
        _isRepositioning = false;
        _repositionOriginalPosition = null;
        _areYouComingToTheTree = false;
        CloseCharacterEditor();
        _editingTitleFeature = null;
        _editingTitleOriginalPosition = null;
        _isDraggingTitleFeature = false;
    }

    private void OpenCharacterEditor(CharacterFeatureDto character, bool readOnly, bool resetRelationshipForm)
    {
        CancelRelationshipEdit();
        _editingCharacter = character;
        _isCharacterEditorOpen = true;
        _isCharacterEditorReadOnly = readOnly;
        if (resetRelationshipForm)
        {
            ResetRelationshipForm();
        }
    }

    private void CloseCharacterEditor()
    {
        CancelRelationshipEdit();
        _editingCharacter = null;
        _isCharacterEditorOpen = false;
        _isCharacterEditorReadOnly = false;
        if (!_isSelectingRelationshipTarget)
        {
            ResetRelationshipForm();
        }
        TryReturnToIdle();
    }

    // ── Point feature editor ─────────────────────────────────────────────────

    // Fraction of the canvas width covered by the overlay panel (matches the CSS 40%).
    private const float PointEditorPanelFraction = 0.4f;

    private void CenterViewOnPoint(float mapX, float mapY)
    {
        _viewX = mapX - CanvasWidth / (2f * _zoom);
        _viewY = mapY - CanvasHeight / (2f * _zoom);
        ClampView();
    }

    // When the panel is visible it covers the right 40% of the canvas.
    // Centre the feature in the remaining left 60% so it isn't hidden behind the panel.
    private const float EditFocusZoom = 2.0f;
    private void CenterViewOnPointInEditor(float mapX, float mapY)
    {
        // Snap to a comfortable editing zoom level.
        _zoom = Math.Clamp(EditFocusZoom, MinZoom, MaxZoom);

        // The panel overlays the right 40 % of the canvas.
        // Visible strip: left 60 % → virtual pixels 0–600.
        // We aim to place the feature at the centre of that strip (px 300),
        // with a 40 px margin from the panel edge (max allowed: px 560).
        const float visibleFraction = 1f - PointEditorPanelFraction; // 0.6
        const float edgeMarginVx    = 40f;
        var panelLeftVx    = CanvasWidth * visibleFraction;        // 600
        var targetVx       = panelLeftVx / 2f;                     // 300
        var maxAllowedVx   = panelLeftVx - edgeMarginVx;           // 560

        // First attempt: centre at edit zoom.
        _viewX = mapX - targetVx / _zoom;
        _viewY = mapY - CanvasHeight / (2f * _zoom);
        ClampView();

        // Check whether clamping pushed the feature behind the panel.
        // Virtual-pixel position of the feature: (mapX − _viewX) × zoom.
        var featureVx = (mapX - _viewX) * _zoom;
        if (featureVx <= maxAllowedVx)
        {
            return; // Feature is comfortably in the visible strip — done.
        }

        // Feature is behind the panel (right-edge case).
        // Minimum zoom that keeps it in the visible strip when the view is at max pan:
        //   (mapX − maxViewX) × zoom ≤ maxAllowedVx
        //   (mapX − MapWidth + CanvasWidth/zoom) × zoom ≤ maxAllowedVx
        //   → zoom ≥ (CanvasWidth − maxAllowedVx) / (MapWidth − mapX)
        var distFromEdge = MapWidth - mapX;
        if (distFromEdge <= 0.1f)
        {
            return; // Feature is at the very map boundary — nothing more we can do.
        }

        var neededZoom = (CanvasWidth - maxAllowedVx) / distFromEdge; // e.g. 440 / dist

        // Zoom IN only (never zoom out) and never exceed MaxZoom.
        _zoom = Math.Clamp(neededZoom, _zoom, MaxZoom);

        // Re-centre with the new zoom and clamp.
        _viewX = mapX - targetVx / _zoom;
        _viewY = mapY - CanvasHeight / (2f * _zoom);
        ClampView();
    }

    private async Task OpenPointFeatureEditorAsync()
    {
        if (_editingPointFeature is null)
        {
            return;
        }

        PushUndoState();
        _isPointFeatureEditorOpen = true;
        var pos = GetPointFeaturePosition(_editingPointFeature);
        if (pos is not null)
        {
            CenterViewOnPointInEditor(pos.X, pos.Y);
        }

        _statusMessage = "Editing feature. Use the panel on the right.";
        await DrawAsync();
    }

    private async Task DoneEditingPointFeatureAsync()
    {
        if (_editingPointFeature is not null)
        {
            TrackEditedPointFeature(_editingPointFeature);
        }

        var returnToTree = _areYouComingToTheTree;
        _areYouComingToTheTree = false;
        _isPointFeatureEditorOpen = false;
        ClearEditSelection(true);

        if (returnToTree)
        {
            _statusMessage = "Character updated.";
            await DrawAsync();
            await OpenRelationshipTreeAsync();
            return;
        }

        _statusMessage = "Feature updated.";
        TryReturnToIdle();
        await DrawAsync();
    }

    private async Task BeginRepositionAsync()
    {
        if (_editingPointFeature is null)
        {
            return;
        }

        _repositionOriginalPosition = GetPointFeaturePosition(_editingPointFeature);
        _isRepositioning = true;
        _isPointFeatureEditorOpen = false;
