    private async Task CancelRepositionAsync()
    {
        if (_editingPointFeature is not null && _repositionOriginalPosition is not null)
        {
            UpdatePointFeaturePosition(_editingPointFeature, _repositionOriginalPosition.X, _repositionOriginalPosition.Y);
        }

        _isRepositioning = false;
        _repositionOriginalPosition = null;
        _isPointFeatureEditorOpen = true;
        if (_editingPointFeature?.Character is not null)
        {
            _isCharacterEditorOpen = true;
        }
        var pos = _editingPointFeature is not null ? GetPointFeaturePosition(_editingPointFeature) : null;
        if (pos is not null)
        {
            CenterViewOnPointInEditor(pos.X, pos.Y);
        }

        _statusMessage = "Reposition cancelled.";
        await DrawAsync();
    }

