    // ── Dialog state classes ──────────────────────────────────
    private sealed class ConfirmDialogState
    {
        public bool IsOpen { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public TaskCompletionSource<bool>? Tcs { get; set; }
    }

    private sealed class PromptDialogState
    {
        public bool IsOpen { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
        public TaskCompletionSource<string?>? Tcs { get; set; }
    }

    // ── Dialog helpers ────────────────────────────────────────
    // Both dialogs use a TaskCompletionSource so callers can await the result directly
    // without callback indirection. The TCS is resolved by the confirm/cancel buttons.
    private Task<bool> ShowConfirmDialogAsync(string title, string message)
    {
        _confirmDialog.Title = title;
        _confirmDialog.Message = message;
        _confirmDialog.Tcs = new TaskCompletionSource<bool>();
        _confirmDialog.IsOpen = true;
        StateHasChanged();
        return _confirmDialog.Tcs.Task;
    }

    private void ConfirmDialogConfirm()
    {
        var tcs = _confirmDialog.Tcs;
        _confirmDialog.IsOpen = false;
        _confirmDialog.Tcs = null;
        tcs?.TrySetResult(true);
    }

    private void ConfirmDialogCancel()
    {
        var tcs = _confirmDialog.Tcs;
        _confirmDialog.IsOpen = false;
        _confirmDialog.Tcs = null;
        tcs?.TrySetResult(false);
    }

    private async Task<string?> ShowPromptDialogAsync(string title, string initialValue)
    {
        _promptDialog.Title = title;
        _promptDialog.Value = initialValue;
        _promptDialog.Tcs = new TaskCompletionSource<string?>();
        _promptDialog.IsOpen = true;
        StateHasChanged();
        await Task.Yield(); // let Blazor render before we focus
        try { await JS.InvokeVoidAsync("inkAndRealmDemo.focusElement", _promptDialogInputRef); } catch { }
        return await _promptDialog.Tcs.Task;
    }

    private void PromptDialogConfirm()
    {
        var tcs = _promptDialog.Tcs;
        var value = _promptDialog.Value;
        _promptDialog.IsOpen = false;
        _promptDialog.Tcs = null;
        tcs?.TrySetResult(value);
    }

    private void PromptDialogCancel()
    {
        var tcs = _promptDialog.Tcs;
        _promptDialog.IsOpen = false;
        _promptDialog.Tcs = null;
        tcs?.TrySetResult(null);
    }

    private void PromptDialogKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            PromptDialogConfirm();
        else if (e.Key == "Escape")
            PromptDialogCancel();
    }
