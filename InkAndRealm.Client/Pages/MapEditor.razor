@page "/map-demo/{MapId:int}"
@using System
@using System.Net
@using System.Net.Http.Json
@using System.Linq
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Web
@using InkAndRealm.Shared
@using InkAndRealm.Client.State
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject UserState UserState
@implements IDisposable

<PageTitle>Ink & Realm Map Editor</PageTitle>

<SectionContent SectionName="top-bar-left">
    <div class="map-ribbon">
        <div class="map-ribbon-top-row">
            <button class="map-ribbon-back" @onclick="GoHome" aria-label="Back" title="Back">
                &#8592;
            </button>
            <div class="map-ribbon-tabs">
                <button class="map-ribbon-tab @(_isMapSettingsModalOpen ? "map-ribbon-tab--active" : "")" @onclick="ToggleMapSettingsModal">Map Settings</button>
                <button class="map-ribbon-tab @(_isStyleSettingsModalOpen ? "map-ribbon-tab--active" : "")" @onclick="ToggleStyleSettingsModal">Style Settings</button>
                <button class="map-ribbon-tab @(_isRelationshipTreeOpen ? "map-ribbon-tab--active" : "")" @onclick="OpenRelationshipTreeAsync" disabled="@_isPointFeatureEditorOpen">Character Tree</button>
                <button class="map-ribbon-tab @(_isPostSettingsOpen ? "map-ribbon-tab--active" : "")" @onclick="TogglePostSettingsAsync">Post Settings</button>
                <div class="map-ribbon-tab-wrapper">
                    <button class="map-ribbon-tab @(_isExportMenuOpen ? "map-ribbon-tab--active" : "")" @onclick="ToggleExportMenu">Export</button>
                    @if (_isExportMenuOpen)
                    {
                        <div class="map-export-dropdown">
                            <div class="map-export-dropdown-header">
                                <span class="map-export-dropdown-title">Export Map</span>
                                <button class="map-export-dropdown-close" @onclick="ToggleExportMenu">&times;</button>
                            </div>
                            <div class="map-export-dropdown-body">
                                <label class="map-export-label">Suggested name</label>
                                <div class="map-export-filename-row">
                                    <input class="map-export-input" type="text" @bind="_exportFileName" @bind:event="oninput" placeholder="my-map" />
                                    <span class="map-export-ext">.png</span>
                                </div>
                                <button class="map-export-btn" @onclick="PerformExportAsync">Export PNG</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="map-ribbon-tool-row">
            <button class="map-ribbon-action-btn"
                    disabled="@(!CanUndo)"
                    @onclick="() => SelectTool(MapToolType.Undo)"
                    title="Undo">
                &#8630;
            </button>
            <button class="map-ribbon-action-btn"
                    disabled="@(!CanRedo)"
                    @onclick="() => SelectTool(MapToolType.Redo)"
                    title="Redo">
                &#8631;
            </button>
            <div class="map-ribbon-divider"></div>
            @if (_activeTool == MapToolType.Brush)
            {
                <div class="map-ribbon-control">
                    <span class="map-ribbon-control-label">Tightness</span>
                    <input class="map-ribbon-slider" type="range" min="1" max="10" step="1" @bind="_brushTightness" />
                </div>
                <div class="map-ribbon-control">
                    <span class="map-ribbon-control-label">Size</span>
                    <input class="map-ribbon-slider" type="range" min="1" max="10" step="1" @bind="_brushSize" />
                </div>
                <div class="map-ribbon-control">
                    <span class="map-ribbon-control-label">Density</span>
                    <input class="map-ribbon-slider" type="range" min="1" max="10" step="1" @bind="_polygonDensity" />
                </div>
            }
            else if (_activeTool == MapToolType.Polygon)
            {
                <div class="map-ribbon-control">
                    <span class="map-ribbon-control-label">Density</span>
                    <input class="map-ribbon-slider" type="range" min="1" max="10" step="1" @bind="_polygonDensity" />
                </div>
            }
            else if (_activeTool == MapToolType.Point)
            {
                @if (ShowPointSize)
                {
                    <div class="map-ribbon-control">
                        <span class="map-ribbon-control-label">Point (@($"{SelectedPointSize:0.0}x"))</span>
                        <input class="map-ribbon-slider" type="range"
                               min="@PointSizeMin" max="@PointSizeMax" step="@PointSizeStep"
                               @bind="SelectedPointSize" @bind:event="oninput" />
                    </div>
                }
            }
            else if (_activeTool == MapToolType.Eraser)
            {
                <div class="map-ribbon-control">
                    <span class="map-ribbon-control-label">Target</span>
                    <select class="map-ribbon-select"
                            value="@_eraserTarget"
                            @onchange="e => SelectEraserTarget(Enum.Parse<EraserTarget>(e.Value!.ToString()!))">
                        @foreach (var target in EraserTargetDefinitions)
                        {
                            <option value="@target.Target">@target.Label</option>
                        }
                    </select>
                </div>
            }
            @if (ShowTitleSize)
            {
                <div class="map-ribbon-divider"></div>
                <div class="map-ribbon-control">
                    <span class="map-ribbon-control-label">Title (@($"{SelectedTitleSize:0.0}x"))</span>
                    <input class="map-ribbon-slider" type="range"
                           min="@TitleSizeMin" max="@TitleSizeMax" step="@TitleSizeStep"
                           @bind="SelectedTitleSize" @bind:event="oninput" />
                </div>
            }
            @if (ShowChaoticEdgesToggle)
            {
                <div class="map-ribbon-divider"></div>
                <div class="map-ribbon-control-check">
                    <input type="checkbox" id="land-chaos-ribbon" @bind="UseChaoticLandEdges" />
                    <label for="land-chaos-ribbon">Chaotic Edges</label>
                </div>
                @if (_useChaoticLandEdges)
                {
                    <div class="map-ribbon-control">
                        <span class="map-ribbon-control-label">Intensity</span>
                        <input class="map-ribbon-slider" type="range" min="1" max="10" step="1"
                               @bind="LandChaosIntensity" @bind:event="oninput" />
                    </div>
                }
            }
            @if (ShowWaterCurvesToggle)
            {
                <div class="map-ribbon-divider"></div>
                <div class="map-ribbon-control-check">
                    <input type="checkbox" id="water-curves-ribbon" @bind="UseWaterCurves" />
                    <label for="water-curves-ribbon">Curves</label>
                </div>
            }
            @if (CanGenerateStarterLandMass)
            {
                <div class="map-ribbon-divider"></div>
                <button class="map-ribbon-action-btn map-ribbon-action-btn--text"
                        @onclick="GenerateStarterLandMassAsync"
                        title="Generate a starter land mass on the active layer">
                    Starter Land Mass
                </button>
            }
        </div>
    </div>
</SectionContent>

<div class="container-fluid map-editor-page">
    <div class="map-editor-layout">
        <aside class="map-editor-sidebar">
            <div class="map-editor-tool-grid" role="group" aria-label="Tool selection">
                @foreach (var tool in ToolDefinitions.Where(t => t.Tool != MapToolType.Undo && t.Tool != MapToolType.Redo))
                {
                    <button class="btn btn-sm map-editor-tool-button @(_activeTool == tool.Tool ? "btn-primary" : "btn-outline-primary")"
                            aria-label="@tool.Label"
                            @onclick="() => SelectTool(tool.Tool)">
                        <span class="map-editor-tool-icon" aria-hidden="true">@GetToolIcon(tool.Tool)</span>
                        <span class="map-editor-tool-tooltip" role="tooltip">@tool.Label</span>
                    </button>
                }
            </div>
        </aside>

        <section class="map-editor-main">
            <div class="map-editor-canvas-area">
                <div class="map-editor-canvas-card">
                    <div class="map-editor-canvas-shell">
                        <canvas id="@CanvasId"
                                width="1000"
                                height="600"
                                class="map-editor-canvas @(_mapStyle == "Parchment" ? "map-canvas--parchment" : "")"
                                style="touch-action:none;"
                                @onmousedown="HandlePointerDown"
                                @onmousemove="HandlePointerMove"
                                @onmouseup="HandlePointerUp"
                                @onmouseleave="HandlePointerLeave"
                                @oncontextmenu="HandleContextMenu"
                                @oncontextmenu:preventDefault="true"
                                @onwheel="HandleWheel"
                                @onwheel:preventDefault="true">
                        </canvas>
                        @if (_isRepositioning)
                        {
                            <div class="map-editor-reposition-overlay">
                                <div class="small text-white-50">Click on the map to place here</div>
                                <button class="btn btn-outline-light btn-sm" @onclick="CancelRepositionAsync">
                                    Cancel
                                </button>
                            </div>
                        }
                        @if (_isSelectingRelationshipTarget)
                        {
                            <div class="map-editor-reposition-overlay">
                                <div class="small text-white-50">Pick a relationship target</div>
                                <button class="btn btn-outline-light btn-sm" @onclick="CancelRelationshipTargetSelection">
                                    Cancel
                                </button>
                            </div>
                        }
                    </div>

                    @if (_isPointFeatureEditorOpen && _editingPointFeature is not null)
                    {
                        <div class="point-feature-editor-panel">
                            <div class="point-feature-editor-header">
                                <div>
                                    <div class="fw-semibold">Edit @GetEditingPointFeatureLabel()</div>
                                </div>
                                <button class="btn btn-primary btn-sm" @onclick="DoneEditingPointFeatureAsync">
                                    Done
                                </button>
                            </div>
                            @if (_editingPointFeature.Character is not null)
                            {
                                <div class="point-feature-editor-tab-bar">
                                    <button class="point-feature-editor-tab @(_characterEditorActiveTab == CharacterEditorTab.Character ? "point-feature-editor-tab--active" : "")"
                                            @onclick="() => _characterEditorActiveTab = CharacterEditorTab.Character">
                                        Character
                                    </button>
                                    <button class="point-feature-editor-tab @(_characterEditorActiveTab == CharacterEditorTab.Relationships ? "point-feature-editor-tab--active" : "")"
                                            @onclick="() => _characterEditorActiveTab = CharacterEditorTab.Relationships">
                                        Relationships
                                    </button>
                                    <button class="point-feature-editor-tab @(_characterEditorActiveTab == CharacterEditorTab.Style ? "point-feature-editor-tab--active" : "")"
                                            @onclick="() => _characterEditorActiveTab = CharacterEditorTab.Style">
                                        Style
                                    </button>
                                </div>
                            }
                            <div class="point-feature-editor-body">
                                @if (_editingPointFeature.Character is not null && _characterEditorActiveTab == CharacterEditorTab.Character && _editingCharacter is not null)
                                {
                                    @* ── Character Tab ─────────────────────────────────────────── *@
                                    <div class="point-feature-editor-section">
                                        <label class="form-label">Name</label>
                                        <input class="form-control"
                                               maxlength="@CharacterFieldMaxLength"
                                               @bind="EditingCharacterName"
                                               @bind:event="oninput"
                                               readonly="@IsCharacterEditorReadOnly" />
                                    </div>
                                    <div class="point-feature-editor-section">
                                        <label class="form-label">Background</label>
                                        <textarea class="form-control"
                                                  rows="3"
                                                  maxlength="@CharacterFieldMaxLength"
                                                  @bind="EditingCharacterBackground"
                                                  @bind:event="oninput"
                                                  readonly="@IsCharacterEditorReadOnly"></textarea>
                                    </div>
                                    <div class="point-feature-editor-section">
                                        <label class="form-label">Occupation</label>
                                        <textarea class="form-control"
                                                  rows="2"
                                                  maxlength="@CharacterFieldMaxLength"
                                                  @bind="EditingCharacterOccupation"
                                                  @bind:event="oninput"
                                                  readonly="@IsCharacterEditorReadOnly"></textarea>
                                    </div>
                                    <div class="point-feature-editor-section">
                                        <label class="form-label">Personality</label>
                                        <textarea class="form-control"
                                                  rows="2"
                                                  maxlength="@CharacterFieldMaxLength"
                                                  @bind="EditingCharacterPersonality"
                                                  @bind:event="oninput"
                                                  readonly="@IsCharacterEditorReadOnly"></textarea>
                                    </div>
                                }
                                else if (_editingPointFeature.Character is not null && _characterEditorActiveTab == CharacterEditorTab.Relationships && _editingCharacter is not null)
                                {
                                    @* ── Relationships Tab ──────────────────────────────────────── *@
                                    <div class="point-feature-editor-section">
                                        @if (!IsCharacterEditorReadOnly)
                                        {
                                            @if (_editingCharacter!.Id <= 0)
                                            {
                                                <div class="small text-warning mb-2">Save this character before adding relationships.</div>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-primary btn-sm w-100 mb-3"
                                                        type="button"
                                                        @onclick="BeginAddNewRelationship">
                                                    Add New Relationship
                                                </button>
                                            }
                                        }
                                        @{
                                            var pfeSaved = _editingCharacter!.Relationships?.Where(r => r.Id > 0).ToList() ?? new();
                                            var pfePending = GetPendingRelationshipsForCharacter(_editingCharacter!.Id);
                                        }
                                        @if (pfeSaved.Count == 0 && pfePending.Count == 0)
                                        {
                                            <div class="small text-muted">No relationships yet.</div>
                                        }
                                        else
                                        {
                                            <div class="relationship-list">
                                                @foreach (var rel in pfeSaved)
                                                {
                                                    var isEditing = _editingRelationshipId == rel.Id;
                                                    var hasPendingUpdate = IsRelationshipUpdateStaged(rel.Id);
                                                    <div class="relationship-item @(hasPendingUpdate ? "rel-edited" : "")">
                                                        <div class="relationship-item-header">
                                                            <div class="relationship-item-info">
                                                                <span class="small fw-semibold">@GetRelationshipTargetLabel(rel.TargetFeatureId, rel.TargetFeatureType)</span>
                                                                <div class="relationship-type-tags">
                                                                    @foreach (var t in (rel.RelationshipTypes ?? new()))
                                                                    {
                                                                        <span class="badge bg-secondary">@t</span>
                                                                    }
                                                                    @if (hasPendingUpdate)
                                                                    {
                                                                        <span class="badge bg-warning text-dark">Edited</span>
                                                                    }
                                                                </div>
                                                                @if (!string.IsNullOrWhiteSpace(rel.Description))
                                                                {
                                                                    <div class="small text-muted relationship-item-desc">@rel.Description</div>
                                                                }
                                                            </div>
                                                            @if (!IsCharacterEditorReadOnly)
                                                            {
                                                                <div class="relationship-item-actions">
                                                                    <button class="btn btn-link btn-sm p-0 text-secondary"
                                                                            type="button"
                                                                            title="Edit"
                                                                            @onclick="() => BeginRelationshipEdit(rel)">
                                                                        ✏
                                                                    </button>
                                                                    <button class="btn btn-link btn-sm p-0 text-danger"
                                                                            type="button"
                                                                            title="Delete"
                                                                            @onclick="async () => await DeleteExistingRelationship(rel)">
                                                                        ✕
                                                                    </button>
                                                                </div>
                                                            }
                                                        </div>
                                                        @if (isEditing && !IsCharacterEditorReadOnly)
                                                        {
                                                            <div class="relationship-edit-inline">
                                                                <input class="form-control form-control-sm mb-2"
                                                                       placeholder="Types (comma-separated)"
                                                                       @bind="_relationshipEditTypesInput"
                                                                       @bind:event="oninput" />
                                                                <textarea class="form-control form-control-sm mb-2"
                                                                          rows="2"
                                                                          placeholder="Description (optional)"
                                                                          @bind="_relationshipEditDescription"
                                                                          @bind:event="oninput"></textarea>
                                                                <div class="d-flex gap-2">
                                                                    <button class="btn btn-primary btn-sm"
                                                                            type="button"
                                                                            @onclick="ApplyRelationshipEdit">
                                                                        Save
                                                                    </button>
                                                                    <button class="btn btn-outline-secondary btn-sm"
                                                                            type="button"
                                                                            @onclick="CancelRelationshipEdit">
                                                                        Cancel
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                @foreach (var rel in pfePending)
                                                {
                                                    <div class="relationship-item rel-new">
                                                        <div class="relationship-item-header">
                                                            <div class="relationship-item-info">
                                                                <span class="small fw-semibold">@GetRelationshipTargetLabel(rel.TargetFeatureId, "New")</span>
                                                                <div class="relationship-type-tags">
                                                                    @foreach (var t in (rel.RelationshipTypes ?? new()))
                                                                    {
                                                                        <span class="badge bg-secondary">@t</span>
                                                                    }
                                                                    <span class="badge bg-success">New</span>
                                                                </div>
                                                                @if (!string.IsNullOrWhiteSpace(rel.Description))
                                                                {
                                                                    <div class="small text-muted relationship-item-desc">@rel.Description</div>
                                                                }
                                                            </div>
                                                            @if (!IsCharacterEditorReadOnly)
                                                            {
                                                                <div class="relationship-item-actions">
                                                                    <button class="btn btn-link btn-sm p-0 text-danger"
                                                                            type="button"
                                                                            title="Remove"
                                                                            @onclick="() => RemovePendingRelationship(rel)">
                                                                        ✕
                                                                    </button>
                                                                </div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    @* ── Style Tab (common) ─────────────────────────────────────── *@
                                    @if (_editingPointFeature.Character is not null && _editingCharacter is not null)
                                    {
                                        @* Character: show type buttons *@
                                        <div class="point-feature-editor-section">
                                            <label class="form-label">Type</label>
                                            <div class="point-feature-editor-styles">
                                                @{
                                                    var currentCharStyle = EditingCharacterType;
                                                }
                                                @foreach (var style in CharacterStyles)
                                                {
                                                    var isSelectedCharStyle = string.Equals(style, currentCharStyle, StringComparison.OrdinalIgnoreCase);
                                                    <button class="btn map-editor-style-button @(isSelectedCharStyle ? "btn-primary" : "btn-outline-primary")"
                                                            disabled="@IsCharacterEditorReadOnly"
                                                            @onclick="() => EditingCharacterType = style">
                                                        @if (StylePreviewImagesByPlacement.TryGetValue(PlacementType.Character, out var charStyleImages)
                                                             && charStyleImages.TryGetValue(style, out var charImgUrl))
                                                        {
                                                            <img src="@charImgUrl" alt="" />
                                                        }
                                                        <span>@style</span>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        @* Tree / House: size + style *@
                                        <div class="point-feature-editor-section">
                                            <label class="form-label">Size</label>
                                            <input class="form-range"
                                                   type="range"
                                                   min="@PointSizeMin"
                                                   max="@PointSizeMax"
                                                   step="@PointSizeStep"
                                                   @bind="EditingPointFeatureSize"
                                                   @bind:event="oninput" />
                                            <div class="small text-muted">@EditingPointFeatureSize.ToString("0.0")</div>
                                        </div>
                                        <div class="point-feature-editor-section">
                                            <label class="form-label">Style</label>
                                            <div class="point-feature-editor-styles">
                                                @{
                                                    var currentEditStyle = EditingPointFeatureStyle;
                                                    var editPlacementType = GetEditingPointFeaturePlacementType();
                                                }
                                                @foreach (var style in EditingPointFeatureStyles)
                                                {
                                                    var isSelectedStyle = string.Equals(style, currentEditStyle, StringComparison.OrdinalIgnoreCase);
                                                    <button class="btn map-editor-style-button @(isSelectedStyle ? "btn-primary" : "btn-outline-primary")"
                                                            @onclick="() => SetEditingPointFeatureStyle(style)">
                                                        @if (editPlacementType.HasValue
                                                             && StylePreviewImagesByPlacement.TryGetValue(editPlacementType.Value, out var styleImages)
                                                             && styleImages.TryGetValue(style, out var imgUrl))
                                                        {
                                                            <img src="@imgUrl" alt="" />
                                                        }
                                                        <span>@style</span>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                    <div class="point-feature-editor-section">
                                        <button class="btn btn-outline-secondary w-100" @onclick="BeginRepositionAsync">
                                            Move Position
                                        </button>
                                    </div>
                                    <div class="point-feature-editor-section">
                                        <label class="form-label">Layer</label>
                                        @{
                                            var currentLayerIndex = _editingPointFeature.Tree?.LayerIndex
                                                ?? _editingPointFeature.House?.LayerIndex
                                                ?? _editingPointFeature.Character?.LayerIndex
                                                ?? 0;
                                            var currentLayer = _areaLayers.FirstOrDefault(l => l.LayerIndex == currentLayerIndex);
                                        }
                                        <div class="small text-muted mb-2">
                                            On @(currentLayer is not null ? GetLayerLabel(currentLayer) : $"Layer {currentLayerIndex + 1}")
                                        </div>
                                        @if (_areaLayers.Count > 1)
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                @for (var li = 0; li < _areaLayers.Count; li++)
                                                {
                                                    var layerBtn = _areaLayers[li];
                                                    var liBtnIndex = li;
                                                    var isOnLayer = layerBtn.LayerIndex == currentLayerIndex;
                                                    <button class="btn btn-sm @(isOnLayer ? "btn-primary" : "btn-outline-secondary")"
                                                            disabled="@isOnLayer"
                                                            @onclick="() => MoveEditingPointFeatureToLayer(layerBtn)">
                                                        @GetLayerLabel(layerBtn, liBtnIndex)
                                                    </button>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="small text-muted">No layers available</div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @* ── Layers Panel ──────────────────────────────────────────── *@
                    @if (_hasMap)
                    {
                        <div class="layer-panel">
                            <div class="layer-panel-header">
                                <span class="layer-panel-title">Layers</span>
                                <button class="layer-panel-add-btn" @onclick="AddAreaLayer" title="Add layer">+</button>
                            </div>
                            <div class="layer-panel-body">
                                @for (var li = 0; li < _areaLayers.Count; li++)
                                {
                                    var layer = _areaLayers[li];
                                    var isActive = _activeAreaLayer?.LayerIndex == layer.LayerIndex;
                                    var isRenaming = _renamingLayer?.LayerIndex == layer.LayerIndex;
                                    <div class="layer-panel-item @(isActive ? "layer-panel-item--active" : "")"
                                         @onclick="() => SelectAreaLayer(layer)">
                                        @if (isRenaming)
                                        {
                                            <input class="layer-panel-rename-input"
                                                   value="@_renamingLayerName"
                                                   @oninput="e => _renamingLayerName = e.Value?.ToString() ?? string.Empty"
                                                   @onblur="CommitRenameLayer"
                                                   @onkeydown="HandleLayerRenameKeyDown"
                                                   @onclick:stopPropagation="true" />
                                        }
                                        else
                                        {
                                            <span class="layer-panel-item-name">@GetLayerLabel(layer)</span>
                                            <div class="layer-panel-item-actions">
                                                <button class="layer-panel-action-btn layer-panel-rename-btn"
                                                        title="Rename"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => StartRenameLayer(layer)">✎</button>
                                                @if (_areaLayers.Count > 1)
                                                {
                                                    <button class="layer-panel-action-btn layer-panel-delete-btn"
                                                            title="Delete layer"
                                                            @onclick:stopPropagation="true"
                                                            @onclick="() => PromptDeleteLayerAsync(layer)">✕</button>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="map-editor-bottombar @(_isPointFeatureEditorOpen ? "map-editor-bottombar--inactive" : "")">
                    <div class="map-editor-item-tabs" role="tablist" aria-label="Map item tabs">
                        @foreach (var placement in PlacementDefinitions)
                        {
                            var isSelected = _placementType == placement.PlacementType;
                            var isMenuOpen = _styleMenuOpenFor == placement.PlacementType;
                            var currentStyle = GetStyleForPlacement(placement.PlacementType);
                            var currentStyleImage = GetStyleImageUrl(placement.PlacementType, currentStyle);
                            <div class="map-editor-item-wrapper">
                                @if (isMenuOpen && !_isPointFeatureEditorOpen)
                                {
                                    <div class="map-editor-style-popup" role="listbox" aria-label="@($"{placement.Label} styles")">
                                        @foreach (var style in GetStylesForPlacement(placement.PlacementType))
                                        {
                                            var isSelectedStyle = string.Equals(style, currentStyle, StringComparison.OrdinalIgnoreCase);
                                            <button class="btn map-editor-style-button @(isSelectedStyle ? "btn-primary" : "btn-outline-primary")"
                                                    role="option"
                                                    aria-selected="@isSelectedStyle"
                                                    aria-label="@($"{style} style")"
                                                    @onclick="() => SelectPlacementStyleAndCloseMenu(placement.PlacementType, style)">
                                                <img src="@GetStyleImageUrl(placement.PlacementType, style)" alt="" />
                                            </button>
                                        }
                                    </div>
                                }
                                <button class="btn map-editor-tab-button @(isSelected ? "btn-primary" : "btn-outline-primary")"
                                        role="tab"
                                        aria-selected="@isSelected"
                                        aria-label="@placement.Label"
                                        @onclick="() => HandlePlacementButtonClick(placement.PlacementType)">
                                    <img src="@currentStyleImage" alt="" />
                                    <span>@placement.Label</span>
                                </button>
                            </div>
                        }
                    </div>
                </div>
                @if (_styleMenuOpenFor.HasValue && !_isPointFeatureEditorOpen)
                {
                    <div class="map-editor-style-backdrop" @onclick="CloseStyleMenu"></div>
                }
            </div>
        </section>
    </div>

    @if (_isMapSettingsModalOpen)
    {
        <div class="map-settings-modal-backdrop" @onclick="ToggleMapSettingsModal"></div>
        <div class="map-settings-modal">
            <div class="map-settings-modal-header">
                <span class="map-settings-modal-title">Map Settings</span>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleMapSettingsModal" aria-label="Close">&times;</button>
            </div>
            <div class="map-settings-modal-body">

                <div class="map-settings-modal-section-label">Appearance</div>
                <div class="map-settings-modal-row">
                    <label class="map-settings-modal-label" for="ms-bg-color">Background Color</label>
                    <input id="ms-bg-color"
                           type="color"
                           class="map-settings-modal-color"
                           @bind="BackgroundColor"
                           @bind:event="onchange" />
                </div>
                <div class="map-settings-modal-row">
                    <label class="map-settings-modal-label" for="ms-grid-toggle">Grid Lines</label>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="ms-grid-toggle" @bind="ShowGrid" />
                    </div>
                </div>

                <div class="map-settings-modal-section-label">Map Specs</div>
                <div class="map-settings-modal-specs">
                    <div class="map-settings-modal-spec-item">
                        <span class="map-settings-modal-spec-label">Width</span>
                        <span class="map-settings-modal-spec-value">@((int)_mapWidth) units</span>
                    </div>
                    <div class="map-settings-modal-spec-item">
                        <span class="map-settings-modal-spec-label">Height</span>
                        <span class="map-settings-modal-spec-value">@((int)_mapHeight) units</span>
                    </div>
                    <div class="map-settings-modal-spec-item">
                        <span class="map-settings-modal-spec-label">Aspect Ratio</span>
                        <span class="map-settings-modal-spec-value">@FormatAspectRatio(_mapWidth, _mapHeight)</span>
                    </div>
                </div>

                <div class="map-settings-modal-section-label">Resize Map</div>
                <div class="map-settings-modal-resize-note">
                    Resizing does not move existing content. Min @((int)MinMapWidth)&times;@((int)MinMapHeight), max @((int)MaxMapWidth)&times;@((int)MaxMapHeight).
                </div>
                <div class="map-settings-modal-resize-inputs">
                    <div class="map-settings-modal-resize-field">
                        <label class="map-settings-modal-label" for="ms-width">Width</label>
                        <input id="ms-width"
                               class="form-control form-control-sm map-settings-modal-number"
                               type="number"
                               min="@((int)MinMapWidth)"
                               max="@((int)MaxMapWidth)"
                               step="100"
                               @bind="_mapSettingsWidthInput" />
                    </div>
                    <div class="map-settings-modal-resize-field">
                        <label class="map-settings-modal-label" for="ms-height">Height</label>
                        <input id="ms-height"
                               class="form-control form-control-sm map-settings-modal-number"
                               type="number"
                               min="@((int)MinMapHeight)"
                               max="@((int)MaxMapHeight)"
                               step="100"
                               @bind="_mapSettingsHeightInput" />
                    </div>
                    <button class="btn btn-primary btn-sm map-settings-modal-apply-btn" @onclick="ApplyMapResize">Apply</button>
                </div>

            </div>
        </div>
    }

    @if (_isStyleSettingsModalOpen)
    {
        <div class="map-settings-modal-backdrop" @onclick="ToggleStyleSettingsModal"></div>
        <div class="map-settings-modal style-settings-modal">
            <div class="map-settings-modal-header">
                <span class="map-settings-modal-title">Style Settings</span>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleStyleSettingsModal" aria-label="Close">&times;</button>
            </div>
            <div class="map-settings-modal-body">

                <div class="map-settings-modal-section-label">Map Style</div>
                <div class="style-settings-radio-group">
                    <label class="style-settings-radio-option @(_mapStyle == "FullColor" ? "style-settings-radio-option--active" : "")">
                        <input type="radio"
                               name="mapStyle"
                               value="FullColor"
                               checked="@(_mapStyle == "FullColor")"
                               @onchange="SelectFullColorStyle" />
                        <span class="style-settings-radio-label">Full Color</span>
                        <span class="style-settings-radio-desc">Standard vivid colors</span>
                    </label>
                    <label class="style-settings-radio-option @(_mapStyle == "Parchment" ? "style-settings-radio-option--active" : "")">
                        <input type="radio"
                               name="mapStyle"
                               value="Parchment"
                               checked="@(_mapStyle == "Parchment")"
                               @onchange="SelectParchmentStyle" />
                        <span class="style-settings-radio-label">Parchment</span>
                        <span class="style-settings-radio-desc">Classic aged-paper ink style</span>
                    </label>
                </div>

            </div>
        </div>
    }

    @if (_isPostSettingsOpen)
    {
        <div class="map-settings-modal-backdrop" @onclick="TogglePostSettingsAsync"></div>
        <div class="map-settings-modal post-settings-modal">
            <div class="map-settings-modal-header">
                <span class="map-settings-modal-title">Post Settings</span>
                <button class="btn btn-outline-secondary btn-sm" @onclick="TogglePostSettingsAsync" aria-label="Close">&times;</button>
            </div>
            <div class="map-settings-modal-body">

                @if (_postSettingsLoading)
                {
                    <div class="post-settings-loading">Loading...</div>
                }
                else
                {
                    <div class="map-settings-modal-section-label">Publish to Explore</div>
                    <p class="post-section-desc">Make this map publicly visible to all users on the Explore page.</p>
                    @if (_postSummary?.IsPublished == true)
                    {
                        <div class="publish-active-row">
                            <span class="publish-active-badge">Published</span>
                        </div>
                        <button class="btn btn-outline-secondary btn-sm mt-2"
                                disabled="@_postPublishBusy"
                                @onclick="PostUnpublishAsync">
                            Remove from Explore
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-primary btn-sm"
                                disabled="@_postPublishBusy"
                                @onclick="PostPublishAsync">
                            Publish
                        </button>
                    }

                    <div class="map-settings-modal-section-label mt-3">Share Link</div>
                    <p class="post-section-desc">Generate a code others can use to view this map.</p>
                    @if (_postShare?.IsOpen == true && _postShare is not null)
                    {
                        <div class="share-code-row">
                            <code class="share-code-display">@_postShare.ShareCode</code>
                            <button class="btn btn-outline-secondary btn-sm"
                                    title="Copy code"
                                    @onclick="() => CopyPostShareCodeAsync(_postShare.ShareCode!)">
                                Copy
                            </button>
                        </div>
                        <div class="share-expiry">Expires @FormatPostUtc(_postShare.ExpiresUtc)</div>
                        <button class="btn btn-outline-danger btn-sm mt-2"
                                disabled="@_postShareBusy"
                                @onclick="PostCloseShareAsync">
                            Close Share
                        </button>
                    }
                    else if (!string.IsNullOrWhiteSpace(_postShare?.ShareCode))
                    {
                        <div class="share-code-row">
                            <code class="share-code-display share-code-closed">@_postShare!.ShareCode</code>
                        </div>
                        <div class="share-expiry text-muted">Share is closed.</div>
                        <button class="btn btn-outline-success btn-sm mt-2"
                                disabled="@_postShareBusy"
                                @onclick="PostOpenShareAsync">
                            Re-open Share
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-outline-success btn-sm"
                                disabled="@_postShareBusy"
                                @onclick="PostOpenShareAsync">
                            Generate Share Code
                        </button>
                    }

                    @if (_postEngagement is not null)
                    {
                        <div class="map-settings-modal-section-label mt-3">Engagement</div>
                        <div class="post-engagement-stats">
                            <div class="post-engagement-stat">
                                <span class="post-engagement-icon">&#128065;</span>
                                <span class="post-engagement-value">@_postEngagement.ViewCount</span>
                                <span class="post-engagement-label">Views</span>
                            </div>
                            <div class="post-engagement-stat">
                                <span class="post-engagement-icon">&#9829;</span>
                                <span class="post-engagement-value">@_postEngagement.LikeCount</span>
                                <span class="post-engagement-label">Likes</span>
                            </div>
                        </div>
                    }

                    @if (_postStatusMessage is not null)
                    {
                        <div class="post-status-msg mt-2">@_postStatusMessage</div>
                    }
                }

            </div>
        </div>
    }
</div>

@if (_isRelationshipDetailModalOpen && _selectedRelationshipTarget is not null && _relationshipSourceCharacter is not null)
{
    <div class="map-settings-modal-backdrop" @onclick="CancelRelationshipDetail"></div>
    <div class="map-settings-modal">
        <div class="map-settings-modal-header">
            <span class="map-settings-modal-title">Add Relationship</span>
            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelRelationshipDetail" aria-label="Close">&times;</button>
        </div>
        <div class="map-settings-modal-body">
            <div class="mb-2">
                @{
                    var sourceName = string.IsNullOrWhiteSpace(_relationshipSourceCharacter!.Name)
                        ? GetCharacterMapLabel(_relationshipSourceCharacter)
                        : _relationshipSourceCharacter.Name;
                    var targetName = GetRelationshipTargetLabel(_selectedRelationshipTarget!.TargetId, _selectedRelationshipTarget.IsCharacter ? "Character" : "Feature");
                }
                <label class="map-settings-modal-label">What is @sourceName's relationship with @targetName? <span class="text-danger">*</span></label>
                <input class="form-control form-control-sm"
                       @bind="_relationshipTypesInput"
                       @bind:event="oninput" />
            </div>
            <div class="mb-3">
                <label class="map-settings-modal-label">Description (optional)</label>
                <textarea class="form-control form-control-sm"
                          rows="2"
                          placeholder="Describe the relationship..."
                          @bind="_relationshipDescription"
                          @bind:event="oninput"></textarea>
            </div>
            @if (_selectedRelationshipTarget.IsCharacter)
            {
                <div class="form-check mb-2">
                    <input class="form-check-input"
                           type="checkbox"
                           id="rel-detail-reciprocal"
                           @bind="_relationshipCreateReciprocal" />
                    <label class="form-check-label small" for="rel-detail-reciprocal">
                        Also add reverse relationship
                    </label>
                </div>
                @if (_relationshipCreateReciprocal)
                {
                    <div class="mb-3">
                        <input class="form-control form-control-sm mb-2"
                               placeholder="Reverse types (optional)"
                               @bind="_relationshipReciprocalTypesInput"
                               @bind:event="oninput" />
                        <textarea class="form-control form-control-sm"
                                  rows="2"
                                  placeholder="Reverse description (optional)"
                                  @bind="_relationshipReciprocalDescription"
                                  @bind:event="oninput"></textarea>
                    </div>
                }
            }
            @if (!string.IsNullOrWhiteSpace(_relationshipStatusMessage))
            {
                <div class="small text-warning mb-2">@_relationshipStatusMessage</div>
            }
            <div class="d-flex gap-2">
                <button class="btn btn-primary btn-sm flex-grow-1"
                        type="button"
                        @onclick="ConfirmRelationshipDetail">
                    Confirm
                </button>
                <button class="btn btn-outline-secondary btn-sm"
                        type="button"
                        @onclick="CancelRelationshipDetail">
                    Cancel
                </button>
            </div>
        </div>
    </div>
}

@if (_isCharacterEditorOpen && _editingCharacter is not null && !_isPointFeatureEditorOpen)
{
    <div class="character-editor-overlay">
        <div class="character-editor-card">
            <div class="character-editor-header">
                <div>
                    <div class="fw-semibold">@(_isCharacterEditorReadOnly ? "Character Details (Read-only)" : "Character Details")</div>
                    <div class="small text-muted">
                        @(_isCharacterEditorReadOnly
                            ? "Switch to the Edit tool to modify character details."
                            : "Changes are auto-saved.")
                    </div>
                </div>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => ClearEditSelection(true)">
                    Close
                </button>
            </div>
            <div class="character-editor-body">
                <div class="character-editor-row">
                    <label class="form-label">Type</label>
                    <select class="form-select form-select-sm"
                            @bind="EditingCharacterType"
                            disabled="@IsCharacterEditorReadOnly">
                        @foreach (var style in CharacterStyles)
                        {
                            <option value="@style">@style</option>
                        }
                    </select>
                </div>
                <div class="character-editor-row character-editor-coordinates">
                    <div>
                        <label class="form-label">X</label>
                        <input class="form-control form-control-sm"
                               type="number"
                               step="1"
                               min="0"
                               max="@MapWidth"
                               @bind="EditingCharacterX"
                               @bind:event="oninput"
                               readonly="@IsCharacterEditorReadOnly" />
                    </div>
                    <div>
                        <label class="form-label">Y</label>
                        <input class="form-control form-control-sm"
                               type="number"
                               step="1"
                               min="0"
                               max="@MapHeight"
                               @bind="EditingCharacterY"
                               @bind:event="oninput"
                               readonly="@IsCharacterEditorReadOnly" />
                    </div>
                </div>
                <div class="character-editor-row">
                    <label class="form-label">Name</label>
                    <input class="form-control"
                           maxlength="@CharacterFieldMaxLength"
                           @bind="EditingCharacterName"
                           @bind:event="oninput"
                           readonly="@IsCharacterEditorReadOnly" />
                </div>
                <div class="character-editor-row">
                    <label class="form-label">Background</label>
                    <textarea class="form-control"
                              rows="3"
                              maxlength="@CharacterFieldMaxLength"
                              @bind="EditingCharacterBackground"
                              @bind:event="oninput"
                              readonly="@IsCharacterEditorReadOnly"></textarea>
                </div>
                <div class="character-editor-row">
                    <label class="form-label">Occupation</label>
                    <textarea class="form-control"
                              rows="2"
                              maxlength="@CharacterFieldMaxLength"
                              @bind="EditingCharacterOccupation"
                              @bind:event="oninput"
                              readonly="@IsCharacterEditorReadOnly"></textarea>
                </div>
                <div class="character-editor-row">
                    <label class="form-label">Personality</label>
                    <textarea class="form-control"
                              rows="2"
                              maxlength="@CharacterFieldMaxLength"
                              @bind="EditingCharacterPersonality"
                              @bind:event="oninput"
                              readonly="@IsCharacterEditorReadOnly"></textarea>
                </div>
                @{
                    var editingCharacter = _editingCharacter!;
                    var pendingRelationships = GetPendingRelationshipsForCharacter(editingCharacter.Id);
                }
                <div class="character-editor-row">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <label class="form-label mb-0">Relationships</label>
                        @if (!IsCharacterEditorReadOnly && editingCharacter.Id > 0)
                        {
                            <button class="btn btn-outline-primary btn-sm"
                                    type="button"
                                    @onclick="BeginAddNewRelationship">
                                + Add
                            </button>
                        }
                    </div>
                    @if (!IsCharacterEditorReadOnly && editingCharacter.Id <= 0)
                    {
                        <div class="small text-warning mb-2">Save this character before adding relationships.</div>
                    }
                    @{ var savedRelationships = editingCharacter.Relationships?.Where(r => r.Id > 0).ToList() ?? new(); }
                    @if (savedRelationships.Count == 0 && pendingRelationships.Count == 0)
                    {
                        <div class="small text-muted">No relationships yet.</div>
                    }
                    else
                    {
                        <div class="relationship-list">
                            @foreach (var rel in savedRelationships)
                            {
                                var isEditing = _editingRelationshipId == rel.Id;
                                var hasPendingUpdate = IsRelationshipUpdateStaged(rel.Id);
                                <div class="relationship-item @(hasPendingUpdate ? "rel-edited" : "")">
                                    <div class="relationship-item-header">
                                        <div class="relationship-item-info">
                                            <span class="small fw-semibold">@GetRelationshipTargetLabel(rel.TargetFeatureId, rel.TargetFeatureType)</span>
                                            <div class="relationship-type-tags">
                                                @foreach (var t in (rel.RelationshipTypes ?? new()))
                                                {
                                                    <span class="badge bg-secondary">@t</span>
                                                }
                                                @if (hasPendingUpdate)
                                                {
                                                    <span class="badge bg-warning text-dark">Edited</span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(rel.Description))
                                            {
                                                <div class="small text-muted relationship-item-desc">@rel.Description</div>
                                            }
                                        </div>
                                        @if (!IsCharacterEditorReadOnly)
                                        {
                                            <div class="relationship-item-actions">
                                                <button class="btn btn-link btn-sm p-0 text-secondary"
                                                        type="button"
                                                        title="Edit"
                                                        @onclick="() => BeginRelationshipEdit(rel)">
                                                    ✏
                                                </button>
                                                <button class="btn btn-link btn-sm p-0 text-danger"
                                                        type="button"
                                                        title="Delete"
                                                        @onclick="() => DeleteExistingRelationship(rel)">
                                                    ✕
                                                </button>
                                            </div>
                                        }
                                    </div>
                                    @if (isEditing && !IsCharacterEditorReadOnly)
                                    {
                                        <div class="relationship-edit-inline">
                                            <input class="form-control form-control-sm mb-2"
                                                   placeholder="Types (comma-separated)"
                                                   @bind="_relationshipEditTypesInput"
                                                   @bind:event="oninput" />
                                            <textarea class="form-control form-control-sm mb-2"
                                                      rows="2"
                                                      placeholder="Description (optional)"
                                                      @bind="_relationshipEditDescription"
                                                      @bind:event="oninput"></textarea>
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-primary btn-sm"
                                                        type="button"
                                                        @onclick="ApplyRelationshipEdit">
                                                    Save
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm"
                                                        type="button"
                                                        @onclick="CancelRelationshipEdit">
                                                    Cancel
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            @foreach (var rel in pendingRelationships)
                            {
                                <div class="relationship-item rel-new">
                                    <div class="relationship-item-header">
                                        <div class="relationship-item-info">
                                            <span class="small fw-semibold">@GetRelationshipTargetLabel(rel.TargetFeatureId, "New")</span>
                                            <div class="relationship-type-tags">
                                                @foreach (var t in (rel.RelationshipTypes ?? new()))
                                                {
                                                    <span class="badge bg-secondary">@t</span>
                                                }
                                                <span class="badge bg-success">New</span>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(rel.Description))
                                            {
                                                <div class="small text-muted relationship-item-desc">@rel.Description</div>
                                            }
                                        </div>
                                        @if (!IsCharacterEditorReadOnly)
                                        {
                                            <div class="relationship-item-actions">
                                                <button class="btn btn-link btn-sm p-0 text-danger"
                                                        type="button"
                                                        title="Remove"
                                                        @onclick="() => RemovePendingRelationship(rel)">
                                                    ✕
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (_isRelationshipTreeOpen)
{
    <div class="relationship-tree-overlay">
        <div class="relationship-tree-card">
            <div class="relationship-tree-header">
                <div class="fw-semibold">Character Tree</div>
                <div class="relationship-tree-header-actions">
                    @if (_isRecalculatePromptOpen)
                    {
                        <span class="small text-muted me-1">Recalculate all positions?</span>
                        <button class="btn btn-warning btn-sm me-1" @onclick="ConfirmRecalculatePositions">Recalculate</button>
                        <button class="btn btn-outline-secondary btn-sm me-2" @onclick="CancelRecalculatePositions">Cancel</button>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary btn-sm me-2" @onclick="PromptRecalculatePositions"
                                disabled="@(_isRelationshipTreeLoading || _isSavingTreePositions)">
                            Recalculate Positions
                        </button>
                    }
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CloseRelationshipTree">
                        Close
                    </button>
                </div>
            </div>
            <div class="relationship-tree-body">
                @if (_isRelationshipTreeLoading)
                {
                }
                else if (_relationshipTreeNodes.Count == 0)
                {
                    <div class="text-muted">No saved characters found for this map.</div>
                }
                else
                {
                    <div class="@RelationshipTreeCanvasShellClass"
                         @onmousedown="BeginRelationshipTreePan"
                         @onmousemove="(args) => UpdateRelationshipTreeMouse(args)"
                         @onmouseup="(args) => EndRelationshipTreeMouse(args)"
                         @onmouseleave="(args) => EndRelationshipTreeMouse(args)"
                         @onmousedown:preventDefault="true"
                         @onwheel="HandleRelationshipTreeWheel"
                         @onwheel:preventDefault="true"
                         @onwheel:stopPropagation="true">
                        <svg id="relationship-tree-svg"
                             class="relationship-tree-canvas"
                             viewBox="@RelationshipTreeViewBox"
                             preserveAspectRatio="xMidYMid meet">
                            <defs>
                                <marker id="relationship-tree-arrowhead"
                                        viewBox="0 0 10 10"
                                        refX="8"
                                        refY="5"
                                        markerWidth="7"
                                        markerHeight="7"
                                        orient="auto-start-reverse">
                                    <path d="M 0 0 L 10 5 L 0 10 z" class="relationship-tree-arrowhead" />
                                </marker>
                            </defs>
                            @foreach (var edge in _relationshipTreeMergedEdges)
                            {
                                if (!_relationshipTreeNodeLookup.TryGetValue(edge.NodeAId, out var nodeA)
                                    || !_relationshipTreeNodeLookup.TryGetValue(edge.NodeBId, out var nodeB))
                                {
                                    continue;
                                }

                                <line x1="@nodeA.X"
                                      y1="@nodeA.Y"
                                      x2="@nodeB.X"
                                      y2="@nodeB.Y"
                                      class="relationship-tree-edge"
                                      marker-start="@GetRelationshipTreeMarkerStart(edge)"
                                      marker-end="@GetRelationshipTreeMarkerEnd(edge)">
                                    <title>@GetRelationshipTreeEdgeTooltip(edge)</title>
                                </line>

                                @if (edge.AToB is not null)
                                {
                                    var labelPosition = GetRelationshipTreeLabelPosition(nodeA, nodeB, 0.36f, -12f);
                                    var labelText = GetRelationshipTreeEdgeLabel(edge.AToB);
                                    if (!string.IsNullOrWhiteSpace(labelText))
                                    {
                                        <foreignObject x="@(labelPosition.X - 100f)"
                                                       y="@(labelPosition.Y - 11f)"
                                                       width="200"
                                                       height="22">
                                            <div xmlns="http://www.w3.org/1999/xhtml"
                                                 class="relationship-tree-edge-label">@labelText</div>
                                        </foreignObject>
                                    }
                                }

                                @if (edge.BToA is not null)
                                {
                                    var labelPosition = GetRelationshipTreeLabelPosition(nodeB, nodeA, 0.36f, 12f);
                                    var labelText = GetRelationshipTreeEdgeLabel(edge.BToA);
                                    if (!string.IsNullOrWhiteSpace(labelText))
                                    {
                                        <foreignObject x="@(labelPosition.X - 100f)"
                                                       y="@(labelPosition.Y - 11f)"
                                                       width="200"
                                                       height="22">
                                            <div xmlns="http://www.w3.org/1999/xhtml"
                                                 class="relationship-tree-edge-label">@labelText</div>
                                        </foreignObject>
                                    }
                                }

                            }

                            @foreach (var node in _relationshipTreeNodes)
                            {
                                <g class="@GetRelationshipTreeNodeClass(node)"
                                   @onclick="() => SelectRelationshipTreeNode(node)"
                                   @onmousedown="(args) => BeginNodeDrag(node, args)"
                                   @onmousedown:stopPropagation="true">
                                    <circle cx="@node.X"
                                            cy="@node.Y"
                                            r="@GetRelationshipTreeNodeRadius(node)">
                                        <title>@GetRelationshipTreeNodeTooltip(node)</title>
                                    </circle>
                                    <foreignObject x="@(node.X - 65f)"
                                                   y="@(node.Y + GetRelationshipTreeNodeRadius(node) + 4f)"
