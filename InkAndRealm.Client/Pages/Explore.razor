@page "/explore"
@using System
@using System.Net.Http.Json
@using InkAndRealm.Shared
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Explore – Ink & Realm</PageTitle>

<div class="container py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoHome">&#8592; Back</button>
        <h2 class="mb-0">Explore</h2>
        <button class="btn btn-outline-primary btn-sm ms-auto" @onclick="OpenCodeModal">Enter a map code</button>
    </div>

    @if (_showCodeModal)
    {
        <div class="code-modal-backdrop" @onclick="CloseCodeModal">
            <div class="code-modal-box" @onclick:stopPropagation="true">
                <h5 class="mb-3">Enter a map code</h5>
                <input class="form-control mb-3"
                       placeholder="Map code"
                       @bind="_codeInput"
                       @bind:event="oninput"
                       @onkeydown="OnCodeKeyDown"
                       maxlength="32"
                       autofocus />
                @if (_codeError is not null)
                {
                    <p class="text-danger small mb-2">@_codeError</p>
                }
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CloseCodeModal">Cancel</button>
                    <button class="btn btn-primary btn-sm" @onclick="OpenByCode" disabled="@string.IsNullOrWhiteSpace(_codeInput)">Open</button>
                </div>
            </div>
        </div>
    }

    @if (_isLoading)
    {
        <p class="text-muted">Loading maps…</p>
    }
    else if (_maps.Count == 0)
    {
        <p class="text-muted">No maps have been published yet.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-xl-4 g-3">
            @foreach (var map in _maps)
            {
                <div class="col">
                    <div class="card explore-card">
                        <div class="explore-card-title-row">
                            <span class="explore-card-name">@map.Name</span>
                        </div>
                        <div class="explore-card-clickable" @onclick="() => ViewMap(map.Id)" title="View @map.Name">
                            <canvas id="explore-thumb-@map.Id" class="explore-thumb-canvas" width="500" height="300"></canvas>
                        </div>
                        <div class="explore-card-footer">
                            <span class="explore-author-label">by</span>
                            <span class="explore-author-name">@map.AuthorName</span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private const float ThumbnailWidth = 500f;
    private const float MapWidth = 2000f;
    private const float MapHeight = 1200f;

    private bool _isLoading = true;
    private bool _thumbnailsRendered;
    private List<PublishedMapSummaryDto> _maps = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var maps = await Http.GetFromJsonAsync<List<PublishedMapSummaryDto>>("api/demo-map/explore");
            _maps = maps ?? new();
        }
        catch { /* non-critical */ }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_thumbnailsRendered && _maps.Count > 0 && !_isLoading)
        {
            _thumbnailsRendered = true;
            await RenderThumbnailsAsync();
        }
    }

    private async Task RenderThumbnailsAsync()
    {
        var tasks = _maps.Select(async map =>
        {
            try
            {
                var dto = await Http.GetFromJsonAsync<MapDto>($"api/demo-map/published/{map.Id}");
                if (dto is not null)
                {
                    var renderState = BuildThumbnailRenderState(dto);
                    await JS.InvokeVoidAsync("inkAndRealmDemo.drawMap", $"explore-thumb-{map.Id}", renderState);
                }
            }
            catch { /* thumbnail failure is non-critical */ }
        }).ToList();

        await Task.WhenAll(tasks);
    }

    private static MapRenderStateDto BuildThumbnailRenderState(MapDto map)
    {
        var zoom = ThumbnailWidth / MapWidth;

        var pointFeatures = new List<MapPointFeatureDto>();
        foreach (var tree in map.Trees)
            pointFeatures.Add(new MapPointFeatureDto { FeatureType = "Tree", X = tree.X, Y = tree.Y, StyleKey = tree.TreeType, Size = tree.Size });
        foreach (var house in map.Houses)
            pointFeatures.Add(new MapPointFeatureDto { FeatureType = "House", X = house.X, Y = house.Y, StyleKey = house.HouseType, Size = house.Size });
        foreach (var character in map.Characters)
            pointFeatures.Add(new MapPointFeatureDto { FeatureType = "Character", X = character.X, Y = character.Y, Size = 1f });

        var titleFeatures = map.Titles.Select(t => new MapTitleFeatureDto
        {
            Id = t.Id,
            Name = t.Name,
            X = t.X,
            Y = t.Y,
            Size = t.Size,
            Points = t.Points
        }).ToList();

        return new MapRenderStateDto
        {
            PointFeatures = pointFeatures,
            TitleFeatures = titleFeatures,
            AreaLayers = map.AreaLayers,
            AreaPolygons = map.AreaPolygons,
            BackgroundColor = map.BackgroundColor,
            ShowGrid = map.ShowGrid,
            MapStyle = map.MapStyle,
            ViewState = new MapViewStateDto
            {
                ViewX = 0,
                ViewY = 0,
                Zoom = zoom,
                MapWidth = MapWidth,
                MapHeight = MapHeight
            }
        };
    }

    private void ViewMap(int mapId) => Navigation.NavigateTo($"/map-viewer?published={mapId}");
    private void GoHome() => Navigation.NavigateTo("/");

    // Map code modal
    private bool _showCodeModal;
    private string _codeInput = string.Empty;
    private string? _codeError;

    private void OpenCodeModal()
    {
        _codeInput = string.Empty;
        _codeError = null;
        _showCodeModal = true;
    }

    private void CloseCodeModal() => _showCodeModal = false;

    private void OpenByCode()
    {
        var code = _codeInput.Trim();
        if (string.IsNullOrEmpty(code)) return;
        Navigation.NavigateTo($"/map-viewer?code={Uri.EscapeDataString(code)}");
    }

    private void OnCodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") OpenByCode();
        else if (e.Key == "Escape") CloseCodeModal();
    }
}
