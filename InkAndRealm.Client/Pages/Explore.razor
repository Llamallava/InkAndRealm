@page "/explore"
@using System
@using System.Net.Http.Json
@using InkAndRealm.Shared
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Explore – Ink & Realm</PageTitle>

<div class="container py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <button class="btn btn-outline-secondary btn-sm" @onclick="GoHome">&#8592; Back</button>
        <h2 class="mb-0">Explore</h2>
        <button class="btn btn-outline-primary btn-sm ms-auto" @onclick="OpenCodeModal">Enter a map code</button>
    </div>

    @if (_showCodeModal)
    {
        <div class="code-modal-backdrop" @onclick="CloseCodeModal">
            <div class="code-modal-box" @onclick:stopPropagation="true">
                <h5 class="mb-3">Enter a map code</h5>
                <input class="form-control mb-3"
                       placeholder="Map code"
                       @bind="_codeInput"
                       @bind:event="oninput"
                       @onkeydown="OnCodeKeyDown"
                       maxlength="32"
                       autofocus />
                @if (_codeError is not null)
                {
                    <p class="text-danger small mb-2">@_codeError</p>
                }
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CloseCodeModal">Cancel</button>
                    <button class="btn btn-primary btn-sm" @onclick="OpenByCode" disabled="@string.IsNullOrWhiteSpace(_codeInput)">Open</button>
                </div>
            </div>
        </div>
    }

    <div class="explore-tab-bar mb-4">
        <button class="explore-tab-btn @(_activeTab == ExploreTab.All ? "explore-tab-btn--active" : "")"
                @onclick="() => _activeTab = ExploreTab.All">
            All Maps
        </button>
        <button class="explore-tab-btn @(_activeTab == ExploreTab.Liked ? "explore-tab-btn--active" : "")"
                @onclick="() => _activeTab = ExploreTab.Liked">
            Liked
        </button>
    </div>

    @* All Maps tab — always in DOM so canvas content is preserved on tab switch *@
    <div style="@(_activeTab != ExploreTab.All ? "display:none" : "")">
        @if (_isLoading)
        {
            <p class="text-muted">Loading maps…</p>
        }
        else if (_maps.Count == 0)
        {
            <p class="text-muted">No maps have been published yet.</p>
        }
        else
        {
            @if (_isRenderingThumbnails)
            {
                <div class="d-flex justify-content-center py-5">
                    <div class="spinner-border text-secondary" role="status">
                        <span class="visually-hidden">Loading previews…</span>
                    </div>
                </div>
            }
            <div style="@(_isRenderingThumbnails ? "display:none" : "")">
                <div class="row row-cols-1 row-cols-md-3 row-cols-xl-4 g-3">
                    @foreach (var map in _maps)
                    {
                        var liked = _likedMapIds.Contains(map.Id);
                        var liveLikes = _liveLikeCounts.TryGetValue(map.Id, out var ll) ? ll : map.LikeCount;
                        <div class="col" @key="map.Id">
                            <div class="card explore-card">
                                <div class="explore-card-title-row">
                                    <span class="explore-card-name">@map.Name</span>
                                </div>
                                <div class="explore-card-clickable" @onclick="() => ViewMap(map.Id)" title="View @map.Name">
                                    <canvas id="explore-thumb-@map.Id" class="explore-thumb-canvas" width="500" height="300"></canvas>
                                </div>
                                <div class="explore-card-footer">
                                    <span class="explore-author-label">by</span>
                                    <span class="explore-author-name">@map.AuthorName</span>
                                    <div class="explore-engagement">
                                        <span class="explore-stat" title="Views">&#128065; @map.ViewCount</span>
                                        <button class="explore-like-btn @(liked ? "explore-like-btn--liked" : "")"
                                                title="@(liked ? "Liked" : "Like")"
                                                @onclick="() => ToggleLikeAsync(map.Id)"
                                                @onclick:stopPropagation="true">
                                            @(liked ? "❤️" : "🤍") @liveLikes
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* Liked tab — always in DOM so canvas content is preserved on tab switch *@
    <div style="@(_activeTab != ExploreTab.Liked ? "display:none" : "")">
        @if (LikedMaps.Count == 0 && _likedThumbnailsRendered)
        {
            <p class="text-muted">You haven't liked any maps yet.</p>
        }
        else if (LikedMaps.Count > 0)
        {
            <div class="row row-cols-1 row-cols-md-3 row-cols-xl-4 g-3">
                @foreach (var map in LikedMaps)
                {
                    var liveLikes = _liveLikeCounts.TryGetValue(map.Id, out var ll) ? ll : map.LikeCount;
                    <div class="col" @key="map.Id">
                        <div class="card explore-card">
                            <div class="explore-card-title-row">
                                <span class="explore-card-name">@map.Name</span>
                            </div>
                            <div class="explore-card-clickable" @onclick="() => ViewMap(map.Id)" title="View @map.Name">
                                <canvas id="liked-thumb-@map.Id" class="explore-thumb-canvas" width="500" height="300"></canvas>
                            </div>
                            <div class="explore-card-footer">
                                <span class="explore-author-label">by</span>
                                <span class="explore-author-name">@map.AuthorName</span>
                                <div class="explore-engagement">
                                    <span class="explore-stat" title="Views">&#128065; @map.ViewCount</span>
                                    <button class="explore-like-btn explore-like-btn--liked"
                                            title="Liked"
                                            @onclick:stopPropagation="true">
                                        ❤️ @liveLikes
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private const float ThumbnailWidth = 500f;
    private const float MapWidth = 2000f;
    private const float MapHeight = 1200f;
    private const string LikedMapsKey = "ink_liked_maps";

    private enum ExploreTab { All, Liked }
    private ExploreTab _activeTab = ExploreTab.All;

    private List<PublishedMapSummaryDto> LikedMaps =>
        _maps.Where(m => _likedMapIds.Contains(m.Id)).ToList();

    private bool _isLoading = true;
    private bool _thumbnailsRendered;
    private bool _isRenderingThumbnails;
    private bool _likedThumbnailsRendered;
    private List<PublishedMapSummaryDto> _maps = new();
    private HashSet<int> _likedMapIds = new();
    private Dictionary<int, int> _liveLikeCounts = new();
    private Dictionary<int, MapDto> _fetchedMapDtos = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var maps = await Http.GetFromJsonAsync<List<PublishedMapSummaryDto>>("api/map/explore");
            _maps = maps ?? new();
            if (_maps.Count > 0)
                _isRenderingThumbnails = true;
        }
        catch { /* non-critical */ }
        finally
        {
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadLikedMapIdsAsync();
            StateHasChanged();
        }

        if (!_thumbnailsRendered && _maps.Count > 0 && !_isLoading)
        {
            _thumbnailsRendered = true;
            await RenderThumbnailsAsync();
            _isRenderingThumbnails = false;
            StateHasChanged();
        }

        // Render liked thumbnails eagerly after all-tab thumbnails are done.
        // Both panels are always in the DOM, so canvases are available.
        if (_thumbnailsRendered && !_likedThumbnailsRendered)
        {
            var likedMaps = LikedMaps;
            _likedThumbnailsRendered = true;
            if (likedMaps.Count > 0)
                await RenderLikedThumbnailsAsync(likedMaps);
        }
    }

    private async Task LoadLikedMapIdsAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", LikedMapsKey);
            if (!string.IsNullOrWhiteSpace(json))
            {
                var ids = System.Text.Json.JsonSerializer.Deserialize<List<int>>(json);
                if (ids is not null)
                    _likedMapIds = new HashSet<int>(ids);
            }
        }
        catch { /* non-critical */ }
    }

    private async Task SaveLikedMapIdsAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_likedMapIds.ToList());
            await JS.InvokeVoidAsync("localStorage.setItem", LikedMapsKey, json);
        }
        catch { /* non-critical */ }
    }

    private async Task ToggleLikeAsync(int mapId)
    {
        if (_likedMapIds.Contains(mapId)) return;

        _likedMapIds.Add(mapId);
        var currentCount = _liveLikeCounts.TryGetValue(mapId, out var c) ? c : (_maps.FirstOrDefault(m => m.Id == mapId)?.LikeCount ?? 0);
        _liveLikeCounts[mapId] = currentCount + 1;
        _likedThumbnailsRendered = false; // new canvas will appear; trigger re-render of liked thumbnails

        await SaveLikedMapIdsAsync();

        try
        {
            var result = await Http.PostAsJsonAsync("api/map/like", new LikeMapRequest { MapId = mapId });
            if (result.IsSuccessStatusCode)
            {
                var engagement = await result.Content.ReadFromJsonAsync<MapEngagementDto>();
                if (engagement is not null)
                    _liveLikeCounts[mapId] = engagement.LikeCount;
            }
        }
        catch { /* non-critical — optimistic update already applied */ }
    }

    private async Task ViewMap(int mapId)
    {
        try { await Http.PostAsJsonAsync("api/map/view", new LikeMapRequest { MapId = mapId }); }
        catch { /* non-critical */ }
        Navigation.NavigateTo($"/map-viewer?published={mapId}");
    }

    private async Task RenderThumbnailsAsync()
    {
        var tasks = _maps.Select(async map =>
        {
            try
            {
                var dto = await Http.GetFromJsonAsync<MapDto>($"api/map/published/{map.Id}");
                if (dto is not null)
                {
                    _fetchedMapDtos[map.Id] = dto;
                    var renderState = BuildThumbnailRenderState(dto);
                    await JS.InvokeVoidAsync("inkAndRealmDemo.drawMap", $"explore-thumb-{map.Id}", renderState);
                }
            }
            catch { /* thumbnail failure is non-critical */ }
        }).ToList();

        await Task.WhenAll(tasks);
    }

    private async Task RenderLikedThumbnailsAsync(List<PublishedMapSummaryDto> likedMaps)
    {
        var tasks = likedMaps.Select(async map =>
        {
            try
            {
                if (!_fetchedMapDtos.TryGetValue(map.Id, out var dto))
                {
                    dto = await Http.GetFromJsonAsync<MapDto>($"api/map/published/{map.Id}");
                    if (dto is not null)
                        _fetchedMapDtos[map.Id] = dto;
                }
                if (dto is not null)
                {
                    var renderState = BuildThumbnailRenderState(dto);
                    await JS.InvokeVoidAsync("inkAndRealmDemo.drawMap", $"liked-thumb-{map.Id}", renderState);
                }
            }
            catch { /* thumbnail failure is non-critical */ }
        }).ToList();

        await Task.WhenAll(tasks);
    }

    private static MapRenderStateDto BuildThumbnailRenderState(MapDto map)
    {
        var zoom = ThumbnailWidth / MapWidth;

        var pointFeatures = new List<MapPointFeatureDto>();
        foreach (var tree in map.Trees)
            pointFeatures.Add(new MapPointFeatureDto { FeatureType = "Tree", X = tree.X, Y = tree.Y, StyleKey = tree.TreeType, Size = tree.Size });
        foreach (var house in map.Houses)
            pointFeatures.Add(new MapPointFeatureDto { FeatureType = "House", X = house.X, Y = house.Y, StyleKey = house.HouseType, Size = house.Size });
        foreach (var character in map.Characters)
            pointFeatures.Add(new MapPointFeatureDto { FeatureType = "Character", X = character.X, Y = character.Y, Size = 1f });

        var titleFeatures = map.Titles.Select(t => new MapTitleFeatureDto
        {
            Id = t.Id,
            Name = t.Name,
            X = t.X,
            Y = t.Y,
            Size = t.Size,
            Points = t.Points
        }).ToList();

        return new MapRenderStateDto
        {
            PointFeatures = pointFeatures,
            TitleFeatures = titleFeatures,
            AreaLayers = map.AreaLayers,
            AreaPolygons = map.AreaPolygons,
            BackgroundColor = map.BackgroundColor,
            ShowGrid = false,
            MapStyle = map.MapStyle,
            ViewState = new MapViewStateDto
            {
                ViewX = 0,
                ViewY = 0,
                Zoom = zoom,
                MapWidth = MapWidth,
                MapHeight = MapHeight
            }
        };
    }

    private void GoHome() => Navigation.NavigateTo("/");

    // Map code modal
    private bool _showCodeModal;
    private string _codeInput = string.Empty;
    private string? _codeError;

    private void OpenCodeModal()
    {
        _codeInput = string.Empty;
        _codeError = null;
        _showCodeModal = true;
    }

    private void CloseCodeModal() => _showCodeModal = false;

    private void OpenByCode()
    {
        var code = _codeInput.Trim();
        if (string.IsNullOrEmpty(code)) return;
        Navigation.NavigateTo($"/map-viewer?code={Uri.EscapeDataString(code)}");
    }

    private void OnCodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") OpenByCode();
        else if (e.Key == "Escape") CloseCodeModal();
    }
}
