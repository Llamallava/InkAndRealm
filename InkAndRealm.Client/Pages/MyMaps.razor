@page "/my-maps"
@using System
@using System.Net
@using System.Net.Http.Json
@using InkAndRealm.Shared
@using InkAndRealm.Client.State
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UserState UserState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>My Maps – Ink & Realm</PageTitle>

<div class="container py-4 home-page" @onclick="CloseMenu">
    <div class="d-flex align-items-center gap-3 mb-4">
        <button class="btn btn-outline-secondary btn-sm" @onclick='() => Navigation.NavigateTo("/")'>&larr; Back</button>
        <h2 class="mb-0">My Maps</h2>
    </div>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="alert alert-info mb-3">@_statusMessage</div>
    }

    <div class="d-flex gap-2 mb-4 align-items-center">
        <input class="form-control"
               style="max-width: 320px;"
               placeholder="Map name (optional)"
               disabled="@(_isCreating)"
               @bind="_newMapName" />
        <button class="btn btn-primary"
                disabled="@(_isCreating)"
                @onclick="CreateMapAsync">
            New Map
        </button>
    </div>

    @if (_isLoading)
    {
        <p class="text-muted">Loading maps…</p>
    }
    else if (_maps.Count == 0)
    {
        <p class="text-muted">No maps yet. Create one above to get started.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 row-cols-xl-4 g-3">
            @foreach (var map in _maps)
            {
                <div class="col">
                    <div class="card map-card">
                        <div class="map-card-title-row">
                            <span class="map-card-name">@map.Name</span>
                            <div class="map-card-actions">
                                <button class="post-btn"
                                        @onclick="() => OpenPost(map)"
                                        @onclick:stopPropagation="true">
                                    Post
                                </button>
                                <div class="map-menu-wrapper">
                                    <button class="map-menu-btn"
                                            title="Map options"
                                            @onclick="(e) => ToggleMenu(map.Id, e)"
                                            @onclick:stopPropagation="true">
                                        &#8942;
                                    </button>
                                    @if (_openMenuMapId == map.Id)
                                    {
                                        <div class="map-dropdown-menu" @onclick:stopPropagation="true">
                                            <button class="map-dropdown-item" @onclick="() => StartRename(map)">Rename</button>
                                            <button class="map-dropdown-item map-dropdown-item-danger" @onclick="() => StartDelete(map)">Delete</button>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="map-card-clickable" @onclick="() => OpenMap(map.Id)" title="Open @map.Name">
                            <canvas id="thumb-@map.Id" class="map-thumbnail-canvas" width="500" height="300"></canvas>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_renameMap is not null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-custom">
        <div class="modal-custom-header">
            <span>Rename Map</span>
            <button class="modal-close-btn" @onclick="CloseModals">&times;</button>
        </div>
        <div class="modal-custom-body">
            <input class="form-control"
                   placeholder="New name"
                   @bind="_renameValue"
                   @bind:event="oninput"
                   @onkeydown="OnRenameKeyDown" />
        </div>
        <div class="modal-custom-footer">
            <button class="btn btn-secondary btn-sm" @onclick="CloseModals">Cancel</button>
            <button class="btn btn-primary btn-sm"
                    disabled="@(string.IsNullOrWhiteSpace(_renameValue))"
                    @onclick="ConfirmRenameAsync">
                Rename
            </button>
        </div>
    </div>
}

@if (_deleteMap is not null)
{
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-custom">
        <div class="modal-custom-header">
            <span>Delete Map</span>
            <button class="modal-close-btn" @onclick="CloseModals">&times;</button>
        </div>
        <div class="modal-custom-body">
            <p class="mb-2">Type <strong>@_deleteMap.Name</strong> to confirm deletion.</p>
            <input class="form-control"
                   placeholder="@_deleteMap.Name"
                   @bind="_deleteConfirmValue"
                   @bind:event="oninput"
                   @onkeydown="OnDeleteKeyDown" />
        </div>
        <div class="modal-custom-footer">
            <button class="btn btn-secondary btn-sm" @onclick="CloseModals">Cancel</button>
            <button class="btn btn-danger btn-sm"
                    disabled="@(!string.Equals(_deleteConfirmValue, _deleteMap.Name, StringComparison.OrdinalIgnoreCase))"
                    @onclick="ConfirmDeleteAsync">
                I'm Sure
            </button>
        </div>
    </div>
}

@if (_postMap is not null)
{
    var postShare = GetShare(_postMap.Id);
    var postShareOpen = postShare?.IsOpen == true;
    <div class="modal-backdrop-custom" @onclick="CloseModals"></div>
    <div class="modal-custom post-modal">
        <div class="modal-custom-header">
            <span>Post</span>
            <button class="modal-close-btn" @onclick="CloseModals">&times;</button>
        </div>
        <div class="modal-custom-body">
            <div class="post-section">
                <div class="post-section-label">Publish to Explore</div>
                <p class="post-section-desc">
                    Make this map publicly visible to all users on the Explore page.
                </p>
                @if (_postMap.IsPublished)
                {
                    <div class="publish-active-row">
                        <span class="publish-active-badge">Published</span>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm mt-2"
                            disabled="@_postPublishBusy"
                            @onclick="PostUnpublishAsync">
                        Remove from Explore
                    </button>
                }
                else
                {
                    <button class="btn btn-outline-primary btn-sm"
                            disabled="@_postPublishBusy"
                            @onclick="PostPublishAsync">
                        Publish
                    </button>
                }
            </div>
            <div class="post-section">
                <div class="post-section-label">Share Link</div>
                <p class="post-section-desc">
                    Generate a code others can use to view this map.
                </p>
                @if (postShareOpen && postShare is not null)
                {
                    <div class="share-code-row">
                        <code class="share-code-display">@postShare.ShareCode</code>
                        <button class="btn btn-outline-secondary btn-sm"
                                title="Copy code"
                                @onclick="() => CopyShareCodeAsync(postShare.ShareCode!)">
                            Copy
                        </button>
                    </div>
                    <div class="share-expiry">Expires @FormatUtc(postShare.ExpiresUtc)</div>
                    <button class="btn btn-outline-danger btn-sm mt-2"
                            disabled="@_postShareBusy"
                            @onclick="PostCloseShareAsync">
                        Close Share
                    </button>
                }
                else if (!string.IsNullOrWhiteSpace(postShare?.ShareCode))
                {
                    <div class="share-code-row">
                        <code class="share-code-display share-code-closed">@postShare!.ShareCode</code>
                    </div>
                    <div class="share-expiry text-muted">Share is closed.</div>
                    <button class="btn btn-outline-success btn-sm mt-2"
                            disabled="@_postShareBusy"
                            @onclick="PostOpenShareAsync">
                        Re-open Share
                    </button>
                }
                else
                {
                    <button class="btn btn-outline-success btn-sm"
                            disabled="@_postShareBusy"
                            @onclick="PostOpenShareAsync">
                        Generate Share Code
                    </button>
                }
                @if (_postStatusMessage is not null)
                {
                    <div class="post-status-msg mt-2">@_postStatusMessage</div>
                }
            </div>
        </div>
    </div>
}

@code {
    private const float ThumbnailWidth = 500f;
    private const float ThumbnailHeight = 300f;
    private const float MapWidth = 2000f;
    private const float MapHeight = 1200f;

    private bool _isCreating;
    private bool _isLoading;
    private bool _thumbnailsRendered;
    private string _statusMessage = string.Empty;
    private string _newMapName = string.Empty;
    private List<MapSummaryDto> _maps = new();
    private readonly Dictionary<int, MapShareStatusDto> _sharesByMapId = new();
    private readonly HashSet<int> _pendingShareUpdates = new();

    private int? _openMenuMapId;
    private MapSummaryDto? _renameMap;
    private string _renameValue = string.Empty;
    private MapSummaryDto? _deleteMap;
    private string _deleteConfirmValue = string.Empty;
    private MapSummaryDto? _postMap;
    private bool _postShareBusy;
    private bool _postPublishBusy;
    private string? _postStatusMessage;

    protected override async Task OnInitializedAsync()
    {
        UserState.Changed += OnUserChanged;

        if (UserState.CurrentUser is null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        await LoadMapsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_thumbnailsRendered && _maps.Count > 0 && !_isLoading)
        {
            _thumbnailsRendered = true;
            await RenderThumbnailsAsync();
        }
    }

    private async Task RenderThumbnailsAsync()
    {
        var tasks = _maps.Select(async map =>
        {
            try
            {
                var dto = await Http.GetFromJsonAsync<MapDto>(GetMapUrl(map.Id));
                if (dto is not null)
                {
                    var renderState = BuildThumbnailRenderState(dto);
                    await JS.InvokeVoidAsync("inkAndRealmDemo.drawMap", $"thumb-{map.Id}", renderState);
                }
            }
            catch { /* thumbnail failure is non-critical */ }
        }).ToList();

        await Task.WhenAll(tasks);
    }

    private static MapRenderStateDto BuildThumbnailRenderState(MapDto map)
    {
        var zoom = ThumbnailWidth / MapWidth;

        var pointFeatures = new List<MapPointFeatureDto>();
        foreach (var tree in map.Trees)
            pointFeatures.Add(new MapPointFeatureDto { FeatureType = "Tree", X = tree.X, Y = tree.Y, StyleKey = tree.TreeType, Size = tree.Size });
        foreach (var house in map.Houses)
            pointFeatures.Add(new MapPointFeatureDto { FeatureType = "House", X = house.X, Y = house.Y, StyleKey = house.HouseType, Size = house.Size });
        foreach (var character in map.Characters)
            pointFeatures.Add(new MapPointFeatureDto { FeatureType = "Character", X = character.X, Y = character.Y, Size = 1f });

        var titleFeatures = map.Titles.Select(t => new MapTitleFeatureDto
        {
            Id = t.Id,
            Name = t.Name,
            X = t.X,
            Y = t.Y,
            Size = t.Size,
            Points = t.Points
        }).ToList();

        return new MapRenderStateDto
        {
            PointFeatures = pointFeatures,
            TitleFeatures = titleFeatures,
            AreaLayers = map.AreaLayers,
            AreaPolygons = map.AreaPolygons,
            BackgroundColor = map.BackgroundColor,
            ShowGrid = map.ShowGrid,
            ViewState = new MapViewStateDto
            {
                ViewX = 0,
                ViewY = 0,
                Zoom = zoom,
                MapWidth = MapWidth,
                MapHeight = MapHeight
            }
        };
    }

    private async Task CreateMapAsync()
    {
        _isCreating = true;
        _statusMessage = "Creating a new map…";

        var response = await Http.PostAsJsonAsync("api/demo-map/new", new CreateMapRequest
        {
            UserId = UserState.CurrentUser?.UserId,
            SessionToken = UserState.CurrentUser?.SessionToken,
            Name = string.IsNullOrWhiteSpace(_newMapName) ? null : _newMapName.Trim()
        });

        if (response.IsSuccessStatusCode)
        {
            var map = await response.Content.ReadFromJsonAsync<MapDto>();
            if (map is not null)
            {
                _newMapName = string.Empty;
                Navigation.NavigateTo($"/map-demo/{map.Id}");
                return;
            }

            await LoadMapsAsync();
            return;
        }

        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            await UserState.SetUserAsync(null);
            Navigation.NavigateTo("/");
            return;
        }

        var message = await response.Content.ReadAsStringAsync();
        _statusMessage = string.IsNullOrWhiteSpace(message) ? "Failed to create a new map." : message;
        _isCreating = false;
    }

    private async Task LoadMapsAsync()
    {
        _isLoading = true;
        _thumbnailsRendered = false;
        _statusMessage = string.Empty;

        using var response = await Http.GetAsync(GetMapsUrl());
        if (response.IsSuccessStatusCode)
        {
            var maps = await response.Content.ReadFromJsonAsync<List<MapSummaryDto>>();
            _maps = maps ?? new List<MapSummaryDto>();
            await LoadShareStatusesAsync();
            _isLoading = false;
            return;
        }

        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            await UserState.SetUserAsync(null);
            Navigation.NavigateTo("/");
            return;
        }

        var message = await response.Content.ReadAsStringAsync();
        _maps = new List<MapSummaryDto>();
        _sharesByMapId.Clear();
        _statusMessage = string.IsNullOrWhiteSpace(message) ? "Failed to load maps." : message;
        _isLoading = false;
    }

    private async Task LoadShareStatusesAsync()
    {
        _sharesByMapId.Clear();
        if (_maps.Count == 0) return;

        using var response = await Http.GetAsync(GetSharesUrl());
        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            await UserState.SetUserAsync(null);
            Navigation.NavigateTo("/");
            return;
        }

        if (!response.IsSuccessStatusCode) return;

        var shares = await response.Content.ReadFromJsonAsync<List<MapShareStatusDto>>();
        if (shares is null) return;

        foreach (var share in shares)
            _sharesByMapId[share.MapId] = share;
    }

    private void OpenMap(int mapId) => Navigation.NavigateTo($"/map-demo/{mapId}");

    private void CloseMenu() => _openMenuMapId = null;

    private void ToggleMenu(int mapId, MouseEventArgs e)
    {
        _openMenuMapId = _openMenuMapId == mapId ? null : mapId;
    }

    private void StartRename(MapSummaryDto map)
    {
        _openMenuMapId = null;
        _renameMap = map;
        _renameValue = map.Name;
    }

    private void StartDelete(MapSummaryDto map)
    {
        _openMenuMapId = null;
        _deleteMap = map;
        _deleteConfirmValue = string.Empty;
    }

    private void CloseModals()
    {
        _renameMap = null;
        _deleteMap = null;
        _postMap = null;
        _renameValue = string.Empty;
        _deleteConfirmValue = string.Empty;
        _postStatusMessage = null;
        _postShareBusy = false;
        _postPublishBusy = false;
    }

    private void OpenPost(MapSummaryDto map)
    {
        CloseModals();
        _postMap = map;
    }

    private async Task PostPublishAsync()
    {
        if (_postMap is null || _postPublishBusy) return;
        _postPublishBusy = true;
        _postStatusMessage = null;

        var response = await Http.PostAsJsonAsync("api/demo-map/publish", new PublishMapRequest
        {
            UserId = UserState.CurrentUser?.UserId,
            SessionToken = UserState.CurrentUser?.SessionToken,
            MapId = _postMap.Id
        });

        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            await UserState.SetUserAsync(null);
            Navigation.NavigateTo("/");
            return;
        }

        if (response.IsSuccessStatusCode)
        {
            var updated = await response.Content.ReadFromJsonAsync<MapSummaryDto>();
            if (updated is not null)
            {
                var idx = _maps.FindIndex(m => m.Id == _postMap.Id);
                if (idx >= 0) _maps[idx] = updated;
                _postMap = updated;
            }
        }
        else
        {
            var msg = await response.Content.ReadAsStringAsync();
            _postStatusMessage = string.IsNullOrWhiteSpace(msg) ? "Failed to publish map." : msg;
        }

        _postPublishBusy = false;
    }

    private async Task PostUnpublishAsync()
    {
        if (_postMap is null || _postPublishBusy) return;
        _postPublishBusy = true;
        _postStatusMessage = null;

        var response = await Http.PostAsJsonAsync("api/demo-map/unpublish", new PublishMapRequest
        {
            UserId = UserState.CurrentUser?.UserId,
            SessionToken = UserState.CurrentUser?.SessionToken,
            MapId = _postMap.Id
        });

        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            await UserState.SetUserAsync(null);
            Navigation.NavigateTo("/");
            return;
        }

        if (response.IsSuccessStatusCode)
        {
            var updated = await response.Content.ReadFromJsonAsync<MapSummaryDto>();
            if (updated is not null)
            {
                var idx = _maps.FindIndex(m => m.Id == _postMap.Id);
                if (idx >= 0) _maps[idx] = updated;
                _postMap = updated;
            }
        }
        else
        {
            var msg = await response.Content.ReadAsStringAsync();
            _postStatusMessage = string.IsNullOrWhiteSpace(msg) ? "Failed to unpublish map." : msg;
        }

        _postPublishBusy = false;
    }

    private async Task PostOpenShareAsync()
    {
        if (_postMap is null || _postShareBusy) return;
        _postShareBusy = true;
        _postStatusMessage = null;
        await SetShareStateAsync(_postMap.Id, true);
        _postShareBusy = false;
    }

    private async Task PostCloseShareAsync()
    {
        if (_postMap is null || _postShareBusy) return;
        _postShareBusy = true;
        _postStatusMessage = null;
        await SetShareStateAsync(_postMap.Id, false);
        _postShareBusy = false;
    }

    private async Task CopyShareCodeAsync(string code)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", code);
            _postStatusMessage = "Copied!";
        }
        catch
        {
            _postStatusMessage = code;
        }
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_renameValue))
            await ConfirmRenameAsync();
        else if (e.Key == "Escape")
            CloseModals();
    }

    private async Task OnDeleteKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && string.Equals(_deleteConfirmValue, _deleteMap?.Name, StringComparison.OrdinalIgnoreCase))
            await ConfirmDeleteAsync();
        else if (e.Key == "Escape")
            CloseModals();
    }

    private async Task ConfirmRenameAsync()
    {
        if (_renameMap is null || string.IsNullOrWhiteSpace(_renameValue)) return;

        var mapId = _renameMap.Id;
        var newName = _renameValue.Trim();
        CloseModals();

        var response = await Http.PostAsJsonAsync("api/demo-map/rename", new RenameMapRequest
        {
            UserId = UserState.CurrentUser?.UserId,
            SessionToken = UserState.CurrentUser?.SessionToken,
            MapId = mapId,
            Name = newName
        });

        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            await UserState.SetUserAsync(null);
            Navigation.NavigateTo("/");
            return;
        }

        if (response.IsSuccessStatusCode)
        {
            var updated = await response.Content.ReadFromJsonAsync<MapSummaryDto>();
            if (updated is not null)
            {
                var idx = _maps.FindIndex(m => m.Id == mapId);
                if (idx >= 0) _maps[idx] = updated;
            }
        }
        else
        {
            var msg = await response.Content.ReadAsStringAsync();
            _statusMessage = string.IsNullOrWhiteSpace(msg) ? "Failed to rename map." : msg;
        }
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteMap is null) return;

        var mapId = _deleteMap.Id;
        var confirmName = _deleteConfirmValue;
        CloseModals();

        var response = await Http.PostAsJsonAsync("api/demo-map/delete", new DeleteMapRequest
        {
            UserId = UserState.CurrentUser?.UserId,
            SessionToken = UserState.CurrentUser?.SessionToken,
            MapId = mapId,
            ConfirmName = confirmName
        });

        if (response.StatusCode == HttpStatusCode.Unauthorized)
        {
            await UserState.SetUserAsync(null);
            Navigation.NavigateTo("/");
            return;
        }

        if (response.IsSuccessStatusCode)
        {
            _maps.RemoveAll(m => m.Id == mapId);
            _sharesByMapId.Remove(mapId);
        }
        else
        {
            var msg = await response.Content.ReadAsStringAsync();
            _statusMessage = string.IsNullOrWhiteSpace(msg) ? "Failed to delete map." : msg;
        }
    }

    private async Task SetShareStateAsync(int mapId, bool open)
    {
        if (mapId <= 0 || _pendingShareUpdates.Contains(mapId)) return;

        _pendingShareUpdates.Add(mapId);
        try
        {
            var payload = new MapShareAccessRequest
            {
                UserId = UserState.CurrentUser?.UserId,
                SessionToken = UserState.CurrentUser?.SessionToken,
                MapId = mapId
            };

            var endpoint = open ? "api/demo-map/share/open" : "api/demo-map/share/close";
            using var response = await Http.PostAsJsonAsync(endpoint, payload);

            if (response.StatusCode == HttpStatusCode.Unauthorized)
            {
                await UserState.SetUserAsync(null);
                Navigation.NavigateTo("/");
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                var failure = await response.Content.ReadAsStringAsync();
                _postStatusMessage = string.IsNullOrWhiteSpace(failure) ? "Failed to update sharing." : failure;
                return;
            }

            var updated = await response.Content.ReadFromJsonAsync<MapShareStatusDto>();
            if (updated is not null)
                _sharesByMapId[mapId] = updated;
        }
        finally
        {
            _pendingShareUpdates.Remove(mapId);
        }
    }

    private MapShareStatusDto? GetShare(int mapId) =>
        _sharesByMapId.TryGetValue(mapId, out var share) ? share : null;

    private string FormatUtc(DateTime? utc) =>
        utc.HasValue ? utc.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt") : "N/A";

    private string GetMapsUrl()
    {
        var sessionToken = UserState.CurrentUser?.SessionToken;
        if (!string.IsNullOrWhiteSpace(sessionToken))
            return $"api/demo-map?sessionToken={Uri.EscapeDataString(sessionToken)}";

        var userId = UserState.CurrentUser?.UserId;
        return userId is null ? "api/demo-map" : $"api/demo-map?userId={userId.Value}";
    }

    private string GetSharesUrl()
    {
        var sessionToken = UserState.CurrentUser?.SessionToken;
        if (!string.IsNullOrWhiteSpace(sessionToken))
            return $"api/demo-map/share?sessionToken={Uri.EscapeDataString(sessionToken)}";

        var userId = UserState.CurrentUser?.UserId;
        return userId is null ? "api/demo-map/share" : $"api/demo-map/share?userId={userId.Value}";
    }

    private string GetMapUrl(int mapId)
    {
        var sessionToken = UserState.CurrentUser?.SessionToken;
        if (!string.IsNullOrWhiteSpace(sessionToken))
            return $"api/demo-map/{mapId}?sessionToken={Uri.EscapeDataString(sessionToken)}";

        var userId = UserState.CurrentUser?.UserId;
        return userId is null ? $"api/demo-map/{mapId}" : $"api/demo-map/{mapId}?userId={userId.Value}";
    }

    private void OnUserChanged()
    {
        _ = InvokeAsync(async () =>
        {
            if (UserState.CurrentUser is null)
            {
                Navigation.NavigateTo("/");
                return;
            }
            await LoadMapsAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        UserState.Changed -= OnUserChanged;
    }
}
