@page "/"
@using InkAndRealm.Client.State
@inject NavigationManager Navigation
@inject UserState UserState

<PageTitle>Ink & Realm</PageTitle>

<div class="landing-page">
    <div class="landing-hero">
        <div class="landing-title-block">
            <h1 class="landing-title">Ink &amp; Realm</h1>
            <p class="landing-subtitle">Craft worlds. Tell stories.</p>
        </div>

        <div class="landing-buttons">
            <button class="btn landing-btn landing-btn-primary" @onclick="OnCreateClicked">
                Create
            </button>
            <button class="btn landing-btn landing-btn-secondary" @onclick="OnExploreClicked">
                Explore
            </button>
        </div>
    </div>
</div>

@if (_showLoginModal)
{
    <div class="landing-login-overlay" @onclick="CloseLoginModal">
        <div class="landing-login-card" @onclick:stopPropagation>
            <div class="landing-login-header">
                <span>Sign in to continue</span>
                <button class="btn-close btn-close-white" @onclick="CloseLoginModal" aria-label="Close"></button>
            </div>
            <AccountPanel Compact="false" OnCompleted="OnLoginCompleted" />
        </div>
    </div>
}

@code {
    private bool _showLoginModal;

    private void OnCreateClicked()
    {
        if (UserState.CurrentUser is not null)
            Navigation.NavigateTo("/my-maps");
        else
            _showLoginModal = true;
    }

    private void OnExploreClicked() => Navigation.NavigateTo("/explore");

    private void CloseLoginModal() => _showLoginModal = false;

    private Task OnLoginCompleted()
    {
        _showLoginModal = false;
        Navigation.NavigateTo("/my-maps");
        return Task.CompletedTask;
    }
}
